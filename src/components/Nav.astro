---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
const isAbout = currentPath === '/about';
const isCommissions = currentPath === '/commissions';
const isPress = currentPath === '/press';
---
<header id="site-header">
  <nav>
    <a href="/" class="wordmark">Arts <span>by</span> Justin</a>
    <button class="menu-toggle" aria-label="Toggle menu" id="menuToggle">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="navLinks">
      <li><a href="/" class:list={['nav-link', { active: isHome }]}>Home</a></li>
      <li><a href="/about" class:list={['nav-link', { active: isAbout }]}>The Story</a></li>
      <li><a href="/" class:list={['nav-link', { active: isHome }]}>Portfolio</a></li>
      <li><a href="/commissions" class:list={['nav-link', { active: isCommissions }]}>Commissions</a></li>
      <li><a href="/press" class:list={['nav-link', { active: isPress }]}>Press</a></li>
      <li><a href="/shop" class="nav-cta">Shop Now</a></li>
    </ul>
  </nav>
</header>
<style>
  #site-header {
    position: sticky;
    top: 0; left: 0; right: 0;
    z-index: 200;
    padding: 1.2rem 3rem;
    display: flex;
    align-items: center;
    background: rgba(8,8,8,0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  nav {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .wordmark {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    letter-spacing: 2px;
    color: #f0f0f0;
  }
  .wordmark span { color: #c9a84c; }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    align-items: center;
  }
  .nav-link {
    font-family: 'Inter', sans-serif;
    color: #aaa;
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: color 0.3s;
  }
  .nav-link:hover, .nav-link.active { color: #c9a84c; }
  .nav-cta {
    background: #c9a84c;
    color: #080808;
    padding: 0.55rem 1.4rem;
    font-size: 0.75rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 700;
    font-family: 'Inter', sans-serif;
    transition: background 0.3s;
  }
  .nav-cta:hover { background: #e8c97a; }
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .menu-toggle span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: #f0f0f0;
    transition: all 0.3s ease;
  }
  @media (max-width: 768px) {
    #site-header { padding: 1rem 1.5rem; }
    .menu-toggle { display: flex; }
    .nav-links {
      position: fixed;
      top: 61px; left: 0; right: 0;
      flex-direction: column;
      background: rgba(8,8,8,0.98);
      padding: 2rem;
      gap: 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      transform: translateY(-110%);
      opacity: 0;
      pointer-events: none;
      transition: all 0.3s ease;
    }
    .nav-links.open { transform: translateY(0); opacity: 1; pointer-events: all; }
    .nav-cta { text-align: center; }
  }
</style>
<script>
  document.getElementById('menuToggle')?.addEventListener('click', () => {
    document.getElementById('navLinks')?.classList.toggle('open');
  });
</script>
