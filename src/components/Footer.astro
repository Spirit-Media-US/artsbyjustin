---
const year = new Date().getFullYear();
---
<footer>
  <div class="f-inner">
    <span class="f-logo">Arts <span>by</span> Justin</span>
    <nav class="f-links">
      <a href="/">Home</a>
      <a href="/about">The Story</a>
      <a href="/press">Press</a>
      <a href="/contact">Contact</a>
    </nav>
    <span class="f-copy">© {year} Arts by Justin · Justin Keishing · Raleigh, NC</span>
  </div>
</footer>
<style>
  footer {
    background: #040404;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 3rem;
  }
  .f-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .f-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #f0f0f0;
  }
  .f-logo span { color: #c9a84c; }
  .f-links {
    display: flex;
    gap: 2rem;
  }
  .f-links a {
    color: #777;
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.3s;
    font-family: 'Inter', sans-serif;
  }
  .f-links a:hover { color: #c9a84c; }
  .f-copy {
    color: #777;
    font-size: 0.72rem;
    font-family: 'Inter', sans-serif;
  }
  @media (max-width: 768px) {
    footer { padding: 2rem 1.5rem; }
    .f-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
    .f-links { flex-wrap: wrap; gap: 1rem; }
  }
</style>
