---
export interface Props {
  title: string;
  description?: string;
}

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from '../lib/sanity';

let siteSettings: any = {};
try { siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`) || {}; } catch (e) {}

const defaultDescription = siteSettings?.tagline || 'Bold acrylic paintings, mixed media works, resin art, murals, and 3D pieces — each one a story, each one made with purpose.';
const { title, description = defaultDescription } = Astro.props;
const fullTitle = title === 'Home' ? 'Arts by Justin' : `${title} — Arts by Justin`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --black: #080808;
      --dark: #111;
      --card: #161616;
      --gold: #c9a84c;
      --gold-light: #e8c97a;
      --white: #f0f0f0;
      --gray: #777;
      --gray2: #aaa;
    }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Inter', system-ui, sans-serif;
      line-height: 1.65;
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }

    /* Shared utility classes */
    .label {
      font-size: 0.68rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.5rem;
      display: block;
    }
    .bar {
      width: 50px;
      height: 2px;
      background: var(--gold);
      margin-bottom: 1.5rem;
    }
    .btn-gold {
      background: var(--gold);
      color: var(--black);
      padding: 0.75rem 1.8rem;
      font-size: 0.75rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 700;
      border: none;
      cursor: pointer;
      transition: background 0.3s;
      display: inline-block;
      font-family: 'Inter', sans-serif;
    }
    .btn-gold:hover { background: var(--gold-light); }
    .btn-ghost {
      background: transparent;
      color: var(--white);
      padding: 0.75rem 1.8rem;
      font-size: 0.75rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: 1px solid rgba(255,255,255,0.2);
      cursor: pointer;
      transition: border-color 0.3s, color 0.3s;
      display: inline-block;
      font-family: 'Inter', sans-serif;
    }
    .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }
    .pull-quote {
      margin: 1.8rem 0;
      padding: 1.5rem;
      border-left: 2px solid var(--gold);
      background: rgba(201,168,76,0.04);
    }
    .pull-quote p {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      color: var(--gold-light);
      font-size: 1.02rem;
      line-height: 1.7;
    }
  </style>
</head>
<body>
  <Nav />
  <main><slot /></main>
  <Footer />
</body>
</html>
