---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const settings = siteSettings || {};
const { 
  artistName = 'Justin', 
  email = '', 
  instagramUrl = '',
  commissionInfo = '',
  tagline = 'Mixed media artist. Original works, commissions, and prints.'
} = settings;
---
<Layout title="Commissions" description={`Commission custom work from ${artistName}. Learn about the process and get in touch.`}>
  

  <section class="commissions-hero reveal">
    <h1>Commissions</h1>
    <p>Custom paintings and mixed media work tailored to your vision and space.</p>
  </section>

  <section class="commission-process">
    <div class="process-inner">
      <h2 class="reveal">How It Works</h2>
      <div class="process-steps">
        <div class="step reveal">
          <div class="step-number">01</div>
          <div class="step-content">
            <h3>Inquiry</h3>
            <p>Send a message with your idea, space, and vision. Include reference images, size preferences, and timeline if possible.</p>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-number">02</div>
          <div class="step-content">
            <h3>Consultation</h3>
            <p>We'll discuss your project in detail—materials, scale, budget, and artistic direction to ensure alignment.</p>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-number">03</div>
          <div class="step-content">
            <h3>Proposal & Sketches</h3>
            <p>You'll receive a detailed proposal with initial sketches, materials breakdown, timeline, and pricing.</p>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-number">04</div>
          <div class="step-content">
            <h3>Production</h3>
            <p>Upon deposit, production begins with regular progress updates and photos shared throughout the process.</p>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-number">05</div>
          <div class="step-content">
            <h3>Delivery</h3>
            <p>Final payment upon completion. Professional shipping and installation support available for larger works.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="commission-details">
    <div class="details-grid">
      <div class="detail-block reveal">
        <h3>Typical Timeline</h3>
        <p>Most commissions take <strong>8-12 weeks</strong> from project approval to delivery, depending on scale and complexity.</p>
      </div>
      <div class="detail-block reveal">
        <h3>Budget Range</h3>
        <p>Custom works typically range from <strong>$2,000 to $20,000+</strong> depending on size, materials, and complexity. We work within your budget.</p>
      </div>
      <div class="detail-block reveal">
        <h3>Scale & Materials</h3>
        <p>We work with paintings on canvas and panel, mixed media, installations, and site-specific works. No size is too large or too small.</p>
      </div>
      <div class="detail-block reveal">
        <h3>Limited Availability</h3>
        <p>Justin accepts <strong>2-3 commissions per season</strong> to ensure quality and personal attention to each project.</p>
      </div>
    </div>
  </section>

  {commissionInfo && (
    <section class="commission-info-section">
      <div class="info-inner reveal">
        <h2>Additional Information</h2>
        <div class="info-text">
          {commissionInfo.split('\n\n').map((paragraph: string) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="commission-contact">
    <div class="contact-inner reveal">
      <h2>Ready to Get Started?</h2>
      <p>Send a brief inquiry with your ideas, and we'll discuss bringing your vision to life.</p>
      <div class="contact-buttons">
        {email && (
          <a href={`mailto:${email}`} class="btn-primary">Send Email</a>
        )}
        {instagramUrl && (
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">Message on Instagram</a>
        )}
        <a href="/contact" class="btn-secondary">Use Contact Form</a>
      </div>
    </div>
  </section>

  <div id="ghl-widget-container" style="display:none;"></div>

  
</Layout>

<style>
  .commissions-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 5rem; text-align:center; }
  .commissions-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .commissions-hero p { color:#8B7355; max-width:600px; margin:0 auto; font-size:1.0625rem; line-height:1.75; }
  .commission-process { background:#F7F4EE; padding:6rem 2.5rem; }
  .process-inner { max-width:1000px; margin:0 auto; }
  .commission-process h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; text-align:center; margin-bottom:4rem; }
  .process-steps { display:grid; grid-template-columns:1fr; gap:2rem; }
  .step { display:grid; grid-template-columns:120px 1fr; gap:2rem; padding:2rem; background:white; border:1px solid rgba(139,115,85,0.15); }
  .step-number { font-family:'Playfair Display',serif; font-size:2.5rem; font-weight:700; color:#C4622D; }
  .step-content h3 { font-family:'Playfair Display',serif; font-size:1.25rem; font-weight:600; margin-bottom:0.75rem; color:#1A1A18; }
  .step-content p { color:#3D3D3A; font-size:0.95rem; line-height:1.7; }
  .commission-details { max-width:1280px; margin:0 auto; padding:6rem 2.5rem; }
  .details-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:2.5rem; }
  .detail-block h3 { font-family:'Playfair Display',serif; font-size:1.125rem; font-weight:600; margin-bottom:0.75rem; color:#1A1A18; }
  .detail-block p { color:#3D3D3A; font-size:0.95rem; line-height:1.75; }
  .detail-block strong { color:#C4622D; }
  .commission-info-section { max-width:1000px; margin:0 auto; padding:0 2.5rem 6rem; background:#F7F4EE; padding-left: 2.5rem; padding-right: 2.5rem; }
  .info-inner { }
  .commission-info-section h2 { font-family:'Playfair Display',serif; font-size:1.75rem; font-weight:600; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .info-text { color:#3D3D3A; font-size:1.0625rem; line-height:1.8; }
  .info-text p { margin-bottom:1.5rem; }
  .commission-contact { background:#1A1A18; color:#EDE8DF; padding:6rem 2.5rem; text-align:center; }
  .contact-inner { max-width:700px; margin:0 auto; }
  .contact-inner h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .contact-inner p { color:#8B7355; font-size:1.0625rem; line-height:1.75; margin-bottom:2.5rem; }
  .contact-buttons { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; }
  .btn-primary { display:inline-block; background:#C4622D; color:#F7F4EE; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s; text-decoration:none; }
  .btn-primary:hover { background:#A8501F; }
  .btn-secondary { display:inline-block; border:1px solid #8B7355; color:#EDE8DF; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:all 0.25s; text-decoration:none; }
  .btn-secondary:hover { background:#8B7355; border-color:#8B7355; }
  @media (max-width:1024px) { 
    .details-grid { grid-template-columns:1fr; }
    .step { grid-template-columns:80px 1fr; }
    .step-number { font-size:2rem; }
  }
  @media (max-width:640px) { 
    .commissions-hero,.commission-process,.commission-details,.commission-info-section,.commission-contact { padding-inline:1.5rem; } 
    .step { grid-template-columns:1fr; gap:1rem; }
    .step-number { font-size:1.75rem; }
    .contact-buttons { flex-direction:column; }
    .btn-primary,.btn-secondary { width:100%; text-align:center; }
  }
</style>
