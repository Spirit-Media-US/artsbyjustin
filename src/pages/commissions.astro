---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const process = [
  { step:'01', title:'Submit Your Inquiry', desc:'Fill out the form below with your ideas, preferred medium, size, and timeline. Justin reviews all inquiries personally.' },
  { step:'02', title:'Consultation', desc:'If the project is a good fit, Justin will reach out to discuss your vision in more detail before any commitment is made.' },
  { step:'03', title:'Proposal & Deposit', desc:'A detailed proposal including pricing, timeline, and scope is sent for your approval. A 50% deposit secures your spot.' },
  { step:'04', title:'The Work', desc:'Justin works in phases, sharing progress images along the way so you can follow the piece as it develops.' },
  { step:'05', title:'Delivery', desc:'Final balance is due upon completion. The finished piece ships carefully packaged with a certificate of authenticity.' },
];
---
<Layout title="Commissions" description="Commission an original painting or mixed media work from Justin. Limited seasonal availability.">
  <Nav slot="nav" />
  <section class="commissions-hero">
    <div class="hero-inner reveal">
      <p class="eyebrow">Custom Work</p>
      <h1>Commission an<br /><em>Original Piece</em></h1>
      <p class="sub">Justin accepts a limited number of commissions each season. If you have a vision for a painting, portrait, or something entirely your own — this is where it begins.</p>
    </div>
  </section>
  <section class="process">
    <div class="process-inner">
      <h2 class="reveal">How it Works</h2>
      <div class="process-steps">
        {process.map((step,i) => (
          <div class="step reveal" style={`animation-delay:${i*0.08}s`}>
            <div class="step-num">{step.step}</div>
            <div class="step-content"><h3>{step.title}</h3><p>{step.desc}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="commission-details reveal">
    <div class="details-grid">
      <div class="detail-card"><h3>Pricing</h3><p>Commission pricing depends on medium, size, and complexity. Inquire for a custom quote — pricing is discussed during the consultation.</p></div>
      <div class="detail-card"><h3>Mediums Available</h3><p>Oil on canvas or board, watercolor, mixed media, charcoal — or a combination. We'll discuss what fits your vision best.</p></div>
      <div class="detail-card"><h3>Timeline</h3><p>Most commissions are completed within 6–12 weeks depending on size and complexity. Rush timelines may be available — ask during inquiry.</p></div>
      <div class="detail-card"><h3>What Makes a Good Fit</h3><p>Justin works best with clients who give creative latitude. Reference photos, mood boards, and descriptive language all help.</p></div>
    </div>
  </section>
  <section class="commission-form-section reveal">
    <div class="form-wrapper">
      <h2>Start Your Inquiry</h2>
      <p>Fill out as much detail as you'd like. Justin reads every submission personally and responds within 3–5 business days.</p>
      <!--
        REPLACE with GoHighLevel embed code.
        GHL: Settings → Forms → Commission Request Form → Embed
        Tag: source:abj-commission  |  Pipeline: Commissions
      -->
      <div class="form-placeholder">
        <p>GoHighLevel Commission Form</p>
        <p class="form-note">Tag: <code>source:abj-commission</code> · Pipeline: Commissions</p>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
<style>
  .commissions-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 6rem; text-align:center; }
  .hero-inner { max-width:700px; margin:0 auto; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1.25rem; }
  .commissions-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; line-height:1.1; letter-spacing:-0.02em; margin-bottom:1.75rem; }
  .commissions-hero h1 em { font-style:italic; color:#C4622D; }
  .sub { font-size:1.0625rem; color:#8B7355; line-height:1.75; max-width:560px; margin:0 auto; }
  .process { max-width:1280px; margin:6rem auto; padding:0 2.5rem; }
  .process h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; margin-bottom:3rem; padding-bottom:1.5rem; border-bottom:1px solid rgba(26,26,24,0.1); }
  .process-steps { display:flex; flex-direction:column; }
  .step { display:grid; grid-template-columns:80px 1fr; gap:2rem; padding:2rem 0; border-bottom:1px solid rgba(26,26,24,0.08); align-items:start; }
  .step-num { font-family:'Playfair Display',serif; font-size:2.5rem; font-weight:700; color:rgba(196,98,45,0.2); line-height:1; }
  .step-content h3 { font-family:'Playfair Display',serif; font-size:1.25rem; font-weight:600; margin-bottom:0.5rem; }
  .step-content p { color:#3D3D3A; line-height:1.7; max-width:600px; }
  .commission-details { background:#EDE8DF; padding:5rem 2.5rem; }
  .details-grid { max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(2,1fr); gap:2rem; }
  .detail-card { background:#F7F4EE; padding:2rem; border-left:3px solid #C4622D; }
  .detail-card h3 { font-family:'Playfair Display',serif; font-size:1.125rem; font-weight:600; margin-bottom:0.75rem; }
  .detail-card p { color:#3D3D3A; line-height:1.7; font-size:0.9375rem; }
  .commission-form-section { max-width:760px; margin:5rem auto 6rem; padding:0 2.5rem; }
  .form-wrapper h2 { font-family:'Playfair Display',serif; font-size:2rem; font-weight:600; margin-bottom:0.75rem; letter-spacing:-0.02em; }
  .form-wrapper > p { color:#3D3D3A; margin-bottom:2.5rem; line-height:1.7; }
  .form-placeholder { background:#EDE8DF; border:2px dashed #8B7355; padding:3rem 2rem; text-align:center; color:#8B7355; }
  .form-placeholder p { margin-bottom:0.5rem; font-weight:500; }
  .form-note { font-size:0.875rem; }
  .form-note code { background:rgba(26,26,24,0.08); padding:0.1rem 0.4rem; font-family:monospace; font-size:0.8rem; }
  @media (max-width:768px) { .details-grid { grid-template-columns:1fr; } .step { grid-template-columns:50px 1fr; gap:1rem; } .commissions-hero,.process,.commission-form-section { padding-inline:1.5rem; } }
</style>
