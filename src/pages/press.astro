---
import Layout from '../layouts/Layout.astro';
import { getAwards, getPressFeatures, urlFor } from '../lib/sanity';

const sanityAwards = await getAwards();
const sanityPress = await getPressFeatures();

// Fallback awards data
const fallbackAwards = [
  { _id: 'a1', title: 'International Prize — Artist of the Year', organization: 'Effetto Arte Fondazione · Florence, Italy', year: 2025, type: 'international', icon: '🏆', description: 'Awarded at the historic Palazzo Pitti for artistic value and global impact. Featured in the official "Master Artists to Collect" publication.' },
  { _id: 'a2', title: 'Cary Magazine Movers & Shakers 2022', organization: 'Cary Magazine · North Carolina', year: 2022, type: 'community', icon: '🥇', description: 'Named one of Western Wake\'s most impactful young professionals — individuals making a difference through business, creativity, and community impact.' },
  { _id: 'a3', title: 'Letter from U.S. House of Representatives', organization: 'Congresswoman Deborah K. Ross · NC 2nd District', year: 2022, type: 'congressional', icon: '🇺🇸', description: 'Personal letter of congratulations from U.S. Congresswoman Deborah K. Ross recognizing Justin\'s lasting impact in Wake County through art and nonprofit work.' },
  { _id: 'a4', title: 'Raleigh Magazine — Kingpin 30s List', organization: 'Raleigh Magazine · 2025', year: 2025, type: 'nomination', icon: '⭐', description: 'Nominated by Raleigh Magazine\'s Editor-in-Chief as a millennial maverick shaping today\'s world — recognized among the elite cast of 30s finalists.' },
  { _id: 'a5', title: 'Best Artist Nominee', organization: 'International Category', year: 2022, type: 'nomination', icon: '🎨', description: 'Nominated in the Best Artist category alongside international artists — recognition of Justin\'s growing global presence and artistic reputation.' },
  { _id: 'a6', title: 'Etsy Star Seller', organization: 'Etsy.com · United States', year: 2021, type: 'platform', icon: '🛒', description: 'Achieved Star Seller status on Etsy — a recognition of exceptional customer service, consistent sales, and outstanding reviews from collectors across America.' },
];

// Fallback press data
const fallbackPress = [
  { _id: 'p1', publication: 'Cary Magazine', type: 'print', title: 'Meet the 2022 Movers & Shakers — Justin Keishing', excerpt: 'A full feature spread in Cary Magazine\'s celebrated Movers & Shakers issue — telling Justin\'s origin story, his journey from India to North Carolina, and his "Chase Your Dreams" series.', date: 'May 2022', image: null, imageUrl: 'https://cdn.sanity.io/images/oqoqh3p3/production/28cf7961bfa771031152630fc04c56dffe1b2bd2-1320x1604.jpg', externalUrl: null },
  { _id: 'p2', publication: 'Ukhrul Times', type: 'newspaper', title: '"Every Canvas is a Journey All Its Own"', excerpt: 'A deep-dive feature on Justin\'s remarkable journey — from a poor orphan boy in Northeast India to becoming a star seller artist in America. Subtitled: "Painting your way out of pain."', date: 'May 9, 2022 · By Soror Shaiza', image: null, imageUrl: 'https://cdn.sanity.io/images/oqoqh3p3/production/c3244071dda31dde815285cd3bdf6e86f5574593-2894x2611.jpg', externalUrl: null },
  { _id: 'p3', publication: 'VoyageRaleigh', type: 'digital', title: '"Check Out Justin Keishing\'s Story"', excerpt: 'Featured in VoyageRaleigh\'s "Raleigh\'s Most Inspiring Stories" series — covering Justin\'s challenges, his faith journey, and how he found his artistic voice during the COVID pandemic.', date: 'January 15, 2026', image: null, imageUrl: 'https://cdn.sanity.io/images/oqoqh3p3/production/6fd936b45bf939ab7dddafce90e275fd097f5fea-1284x2573.jpg', externalUrl: null },
  { _id: 'p4', publication: 'Raleigh Magazine', type: 'nomination', title: 'Kingpin 30s — Millennial Mavericks Shaping the World', excerpt: 'Nominated by Raleigh Magazine\'s Editor-in-Chief Melissa Howsam as one of Raleigh\'s elite millennial leaders — "totally crushing it and promising to be names we\'ll hear for decades to come."', date: 'February 2025', image: null, imageUrl: 'https://cdn.sanity.io/images/oqoqh3p3/production/0426b2863395965050a9dd19899502f2b283116f-3464x3464.jpg', externalUrl: null },
  { _id: 'p5', publication: 'Artist of the Year 2025', type: 'print', title: '"Master Artists to Collect" — International Publication', excerpt: 'Justin\'s "Empress" painting was featured across two full pages in the official Artist of the Year 2025 international publication — distributed globally alongside the Florence award ceremony.', date: 'Florence, Italy · January 2025', image: null, imageUrl: 'https://cdn.sanity.io/images/oqoqh3p3/production/1b8670b5fb4ba996c8664c9c83e8bf7123709dcb-3024x4032.jpg', externalUrl: null },
  { _id: 'p6', publication: 'Spirit Media', type: 'digital', title: 'Congratulations — Cary Movers & Shakers & Etsy Star Seller', excerpt: 'Spirit Media featured and announced Justin\'s Movers & Shakers recognition and his achievement as an Etsy Star Seller — amplifying his story to the North Carolina community.', date: '2022', image: null, imageUrl: 'https://cdn.sanity.io/images/oqoqh3p3/production/2380ba91fad41d9f9512e13985704b544f6c4961-3024x4032.jpg', externalUrl: null },
];

const awards = sanityAwards.length > 0 ? sanityAwards : fallbackAwards;
const pressFeatures = sanityPress.length > 0
  ? sanityPress.map((p: any) => ({ ...p, imageUrl: p.image ? urlFor(p.image).width(800).url() : null }))
  : fallbackPress;
---
<Layout title="Press & Recognition" description="Justin Keishing's awards, press features, and recognition — from Raleigh, NC to Florence, Italy.">

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-tag">
      <div class="hero-line"></div>
      <span>Recognition & Press</span>
      <div class="hero-line"></div>
    </div>
    <h1>Honored.<br/><em>Recognized.</em><br/>Featured.</h1>
    <p>From a small village in Northeast India to international stages — Justin Keishing's art and story have been recognized by publications, award bodies, and institutions around the world.</p>
    <div class="gold-bar"></div>
  </div>
  <div class="hero-right">
    <img src="https://cdn.sanity.io/images/oqoqh3p3/production/0ca95129d6d4f6d7906d7c5fca04770c987737f6-2730x4096.jpg" alt="Justin Keishing — Artist" loading="eager"/>
  </div>
</section>

<!-- HIGHLIGHT STATS -->
<div class="highlights">
  <div class="highlight"><div class="highlight-num">1</div><div class="highlight-label">International Artist of the Year</div></div>
  <div class="highlight"><div class="highlight-num">3+</div><div class="highlight-label">Major Awards & Honors</div></div>
  <div class="highlight"><div class="highlight-num">4+</div><div class="highlight-label">Press Features</div></div>
  <div class="highlight"><div class="highlight-num">1</div><div class="highlight-label">Letter from U.S. Congress</div></div>
</div>

<!-- FEATURED AWARD -->
<section class="featured-award">
  <div class="award-visual">
    <div class="award-accent"></div>
    <div class="award-img-wrap">
      <img src="https://cdn.sanity.io/images/oqoqh3p3/production/13062fa3e35ae8d926b490c155a64abda6037699-1358x926.jpg" alt="Artist of the Year — Florence, Italy 2025"/>
    </div>
    <div class="award-year-badge">Florence · January 2025</div>
  </div>
  <div class="award-body">
    <p class="label">Highest Honor</p>
    <div class="bar"></div>
    <h2>International Prize<br/>Artist of the Year</h2>
    <p class="subtitle">Palazzo Pitti, Florence, Italy · 2025</p>
    <p>Justin Keishing was awarded the International Prize — Artist of the Year 2025 by Effetto Arte Fondazione in collaboration with Russo, presented at the historic Palazzo Pitti in Florence, Italy on January 25th, 2025.</p>
    <p>The award recognized Justin's artistic value and global impact — a remarkable achievement for a self-taught artist from Northeast India now based in Raleigh, North Carolina.</p>
    <p>His "Empress" painting was featured across two full pages in the official Artist of the Year international publication — <em>Master Artists to Collect</em>.</p>
    <div class="location-tag">📍 Palazzo Pitti · Florence, Italy · January 25, 2025</div>
  </div>
</section>

<!-- GALLERY STRIP -->
<div class="gallery-strip">
  <div class="gallery-strip-item"><img src="https://cdn.sanity.io/images/oqoqh3p3/production/206f139dbbdef97c494412f828b09b5e90c02426-3000x4000.jpg" alt="Artwork by Justin Keishing" loading="lazy"/></div>
  <div class="gallery-strip-item"><img src="https://cdn.sanity.io/images/oqoqh3p3/production/b43f0ad0aaa2fc715b9fc21c167ce61b2655b78e-3068x4096.jpg" alt="Artwork by Justin Keishing" loading="lazy"/></div>
  <div class="gallery-strip-item"><img src="https://cdn.sanity.io/images/oqoqh3p3/production/f3a9d25d94594823daa99b03f822163d2bb87403-2730x4096.jpg" alt="Artwork by Justin Keishing" loading="lazy"/></div>
  <div class="gallery-strip-item"><img src="https://cdn.sanity.io/images/oqoqh3p3/production/bd955a438c41cc596b4438c8eff37378f6c6f2ce-4096x2785.jpg" alt="Artwork by Justin Keishing" loading="lazy"/></div>
</div>

<!-- AWARDS GRID -->
<section class="awards">
  <div class="section-intro">
    <p class="label" style="text-align:center;">Awards & Honors</p>
    <div class="bar" style="margin:0.5rem auto 1rem;"></div>
    <h2>A Record of Recognition</h2>
    <p>Each honor a milestone. Each award a reminder that purpose-driven art leaves a mark.</p>
  </div>
  <div class="awards-grid">
    {awards.map((a: any) => (
      <div class:list={['award-card', { congressional: a.type === 'congressional' }]}>
        <div class="yr">{a.year}</div>
        <span class="award-icon-sm">{a.icon || '🏅'}</span>
        <span class:list={['award-badge', a.type === 'congressional' ? 'badge-blue' : a.type === 'nomination' ? 'badge-green' : 'badge-gold']}>
          {a.type === 'international' ? 'International Award'
            : a.type === 'community' ? 'Community Honor'
            : a.type === 'congressional' ? 'Congressional Recognition'
            : a.type === 'platform' ? 'Platform Achievement'
            : 'Nomination'}
        </span>
        <h3>{a.title}</h3>
        <div class="awrd-org">{a.organization}</div>
        <p>{a.description}</p>
      </div>
    ))}
  </div>
</section>

<!-- FULL-WIDTH PHOTO FEATURE -->
<div class="photo-feature">
  <img src="https://cdn.sanity.io/images/oqoqh3p3/production/79f9b5ee6718180013f9f77caf99ad95a0175916-4030x3022.jpg" alt="Justin Keishing at Palazzo Pitti, Florence" loading="lazy"/>
  <div class="photo-feature-overlay"></div>
  <div class="photo-feature-content">
    <p class="label">Florence, Italy · January 2025</p>
    <h2>The Moment<br/>the World Took Notice</h2>
    <p>Standing inside the historic Palazzo Pitti, receiving the International Prize — Artist of the Year. A self-taught artist from a small village in Northeast India, now recognized on the world stage.</p>
  </div>
</div>

<!-- CONGRESSIONAL LETTER -->
<section class="congress">
  <div class="congress-doc">
    <div class="congress-header">
      <div class="seal">🦅</div>
      <h4>Congress of the United States</h4>
      <p>House of Representatives · Washington, DC</p>
    </div>
    <div class="congress-body">
      <p class="salutation">Dear Mr. Keishing,</p>
      <p class="para">On behalf of North Carolina's Second Congressional District, I would like to extend my heartfelt congratulations on being named a Cary Mover & Shaker. This achievement is a testament to the lasting impact you are making in Wake County.</p>
      <p class="para">Your commitment to your art and achieving your goals is admirable. It gives me great hope to know that determined minds such as yours are contributing to the beauty of our community.</p>
      <p class="para">I am grateful for what you have contributed to this area through your nonprofit work and through your art.</p>
      <p class="sig">Very truly yours,</p>
      <p class="congress-sig-name">Deborah K. Ross<br/><span>Member of Congress · July 6, 2022</span></p>
    </div>
  </div>
  <div class="congress-text">
    <p class="label">Congressional Recognition</p>
    <div class="bar"></div>
    <h2>A Letter from<br/>the U.S. Congress</h2>
    <p>In July 2022, Justin received a personal letter of congratulations from U.S. Congresswoman Deborah K. Ross, representing North Carolina's 2nd Congressional District.</p>
    <p>The letter recognized Justin's recognition as a Cary Mover & Shaker and his lasting impact in Wake County through both his art and his nonprofit work with Global Hope India.</p>
    <div class="congress-quote">
      <p>"Your commitment to your art and achieving your goals is admirable. It gives me great hope to know that determined minds such as yours are contributing to the beauty of our community."</p>
    </div>
  </div>
</section>

<!-- PRESS FEATURES -->
<section class="press">
  <div class="section-intro">
    <p class="label" style="text-align:center;">Press & Media</p>
    <div class="bar" style="margin:0.5rem auto 1rem;"></div>
    <h2>In the News</h2>
    <p>Justin's story has been told across print, digital, and community publications — locally, nationally, and internationally.</p>
  </div>
  <div class="press-grid">
    {pressFeatures.map((pf: any) => (
      <div class="press-card">
        {pf.imageUrl && (
          <div class="press-card-img">
            <img src={pf.imageUrl} alt={pf.publication} loading="lazy"/>
          </div>
        )}
        <div class="press-card-top">
          <div class="press-pub">{pf.publication}</div>
          <div class="press-type">
            {pf.type === 'print' ? 'Print Feature'
              : pf.type === 'newspaper' ? 'Newspaper Feature'
              : pf.type === 'nomination' ? 'Nomination'
              : 'Digital Feature'}
          </div>
        </div>
        <div class="press-card-body">
          <h3>{pf.title}</h3>
          <p>{pf.excerpt}</p>
          <div class="press-date">{pf.date}</div>
          {pf.externalUrl && (
            <a href={pf.externalUrl} target="_blank" rel="noopener" class="press-read">Read Article →</a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<!-- NOMINATION HIGHLIGHT -->
<section class="nomination">
  <div class="nom-badge">Latest Recognition</div>
  <h2>Nominated by <em>Raleigh Magazine</em></h2>
  <p>In February 2025, Raleigh Magazine's Editor-in-Chief personally nominated Justin as one of Raleigh's Kingpin 30s — millennial leaders who are "shaping today's world and promising to be names we'll hear ringing loud for decades to come."</p>
  <div class="nom-detail">
    <span>Raleigh Magazine</span> · Kingpin 30s Finalists · <span>February 2025</span>
  </div>
</section>

<!-- ARTIST PHOTO PAIR -->
<div class="photo-pair">
  <div class="photo-pair-item">
    <img src="https://cdn.sanity.io/images/oqoqh3p3/production/b8c57386182cb4c7c5edc377a73f1822c53dfe8c-3024x3780.jpg" alt="Justin Keishing — Artist at work" loading="lazy"/>
    <div class="photo-pair-caption">The Artist at Work</div>
  </div>
  <div class="photo-pair-item">
    <img src="https://cdn.sanity.io/images/oqoqh3p3/production/bd955a438c41cc596b4438c8eff37378f6c6f2ce-4096x2785.jpg" alt="Justin Keishing — Award ceremony" loading="lazy"/>
    <div class="photo-pair-caption">Award Ceremony · Florence 2025</div>
  </div>
</div>

<!-- TIMELINE -->
<section class="timeline">
  <div class="section-intro" style="margin-bottom:4rem;">
    <p class="label" style="text-align:center;">The Journey</p>
    <div class="bar" style="margin:0.5rem auto 1rem;"></div>
    <h2>Recognition Timeline</h2>
    <p>From first art show to international prize — every milestone on the way.</p>
  </div>
  <div class="timeline-inner">
    <div class="tl-item"><div class="tl-year">June 2021</div><h3>First Art Show</h3><p>Justin enters his first art show and is immediately surprised by the public's reaction — people love and purchase his work, launching his career as a professional artist.</p></div>
    <div class="tl-item"><div class="tl-year">2021</div><h3>Etsy Star Seller</h3><p>Achieves Star Seller status on Etsy — his online store grows rapidly with collectors across the United States, UK, France, Canada, and India.</p></div>
    <div class="tl-item"><div class="tl-year">May 2022</div><h3>Cary Magazine — Movers & Shakers</h3><p>Named a 2022 Mover & Shaker by Cary Magazine. Full feature spread published in the May 2022 issue. Receives a glass trophy at the official ceremony.</p></div>
    <div class="tl-item"><div class="tl-year">May 2022</div><h3>Ukhrul Times Feature</h3><p>"Every Canvas is a Journey All Its Own" — a full newspaper feature on Justin's journey from Northeast India to America, published in the Ukhrul Times.</p></div>
    <div class="tl-item"><div class="tl-year">July 2022</div><h3>Letter from U.S. Congress</h3><p>Receives a personal letter from Congresswoman Deborah K. Ross recognizing his impact in Wake County through art and nonprofit work.</p></div>
    <div class="tl-item"><div class="tl-year">January 2025</div><h3>International Prize — Artist of the Year</h3><p>Awarded the International Prize — Artist of the Year 2025 at Palazzo Pitti, Florence, Italy. Featured in the "Master Artists to Collect" international publication.</p></div>
    <div class="tl-item"><div class="tl-year">February 2025</div><h3>Raleigh Magazine — Kingpin 30s Nomination</h3><p>Nominated by Raleigh Magazine's Editor-in-Chief as one of Raleigh's elite millennial leaders shaping the world.</p></div>
    <div class="tl-item"><div class="tl-year">January 2026</div><h3>VoyageRaleigh Feature</h3><p>"Check Out Justin Keishing's Story" published in VoyageRaleigh's Most Inspiring Stories series — reaching a wide digital audience.</p></div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <h2>The story is<br/><em>still being written.</em></h2>
  <p>Press inquiries, gallery partnerships, and commission requests are always welcome.<br/>Let's create something worth recognizing.</p>
  <a href="/contact" class="btn-gold">Press & Media Inquiries →</a>
  <a href="/" class="btn-ghost">View Portfolio →</a>
</section>

</Layout>

<style>
/* HERO */
.hero { min-height:100vh; display:grid; grid-template-columns:1fr 1fr; position:relative; overflow:hidden; }
.hero-left { padding:10rem 3rem 6rem; display:flex; flex-direction:column; justify-content:center; position:relative; z-index:2; background:linear-gradient(135deg,#080808,#0f0800,#080808); }
.hero-left::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 0% 50%,rgba(201,168,76,0.08),transparent 70%); }
.hero-right { position:relative; overflow:hidden; }
.hero-right img { width:100%; height:100%; object-fit:cover; object-position:center top; filter:brightness(0.75); }
.hero-right::after { content:''; position:absolute; inset:0; background:linear-gradient(to right,#080808 0%,transparent 30%),linear-gradient(to top,#080808 0%,transparent 30%); pointer-events:none; }
.hero-tag { display:inline-flex; align-items:center; gap:0.8rem; margin-bottom:2rem; }
.hero-line { width:30px; height:1px; background:var(--gold); flex-shrink:0; }
.hero-tag span { font-size:0.68rem; letter-spacing:4px; text-transform:uppercase; color:var(--gold); }
.hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,5vw,4.5rem); line-height:1.1; margin-bottom:1.5rem; }
.hero h1 em { color:var(--gold); font-style:italic; }
.hero p { color:var(--gray2); font-size:1rem; max-width:480px; line-height:1.9; font-weight:300; }
.gold-bar { width:60px; height:2px; background:var(--gold); margin:2rem 0 0; }

/* HIGHLIGHTS */
.highlights { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:rgba(255,255,255,0.04); border-top:1px solid rgba(255,255,255,0.05); border-bottom:1px solid rgba(255,255,255,0.05); }
.highlight { padding:2.5rem; text-align:center; background:var(--black); }
.highlight-num { font-family:'Playfair Display',serif; font-size:2.8rem; color:var(--gold); line-height:1; margin-bottom:0.4rem; }
.highlight-label { font-size:0.68rem; letter-spacing:3px; text-transform:uppercase; color:var(--gray); }

/* FEATURED AWARD */
.featured-award { padding:6rem 3rem; background:linear-gradient(135deg,#0d0800,#150a00); display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
.award-visual { position:relative; }
.award-img-wrap { aspect-ratio:4/3; position:relative; overflow:hidden; border:1px solid rgba(201,168,76,0.2); }
.award-img-wrap img { width:100%; height:100%; object-fit:cover; object-position:center; }
.award-img-wrap::after { content:''; position:absolute; inset:0; background:linear-gradient(to bottom,transparent 60%,rgba(13,8,0,0.6)); pointer-events:none; }
.award-accent { position:absolute; top:-1rem; left:-1rem; width:50%; height:50%; border:1px solid rgba(201,168,76,0.25); z-index:2; }
.award-year-badge { position:absolute; bottom:-1rem; right:-1rem; background:var(--gold); color:var(--black); padding:0.6rem 1.2rem; font-size:0.7rem; letter-spacing:3px; text-transform:uppercase; font-weight:700; z-index:3; }
.award-body h2 { font-family:'Playfair Display',serif; font-size:2.5rem; line-height:1.2; margin-bottom:0.5rem; }
.award-body .subtitle { color:var(--gold-light); font-size:1rem; font-style:italic; margin-bottom:1.5rem; display:block; }
.award-body p { color:var(--gray2); font-size:0.93rem; line-height:1.9; font-weight:300; margin-bottom:1rem; }
.location-tag { display:inline-flex; align-items:center; gap:0.6rem; margin-top:1rem; padding:0.6rem 1.2rem; border:1px solid rgba(201,168,76,0.3); color:var(--gold); font-size:0.72rem; letter-spacing:2px; text-transform:uppercase; }

/* GALLERY STRIP */
.gallery-strip { display:grid; grid-template-columns:repeat(4,1fr); gap:4px; background:var(--black); }
.gallery-strip-item { aspect-ratio:3/4; overflow:hidden; position:relative; }
.gallery-strip-item img { width:100%; height:100%; object-fit:cover; transition:transform 0.6s ease,filter 0.4s; }
.gallery-strip-item:hover img { transform:scale(1.06); filter:brightness(0.9); }
.gallery-strip-item::after { content:''; position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,0.4),transparent 50%); pointer-events:none; }

/* AWARDS GRID */
.awards { padding:6rem 3rem; background:var(--dark); }
.section-intro { text-align:center; margin-bottom:4rem; }
.section-intro h2 { font-family:'Playfair Display',serif; font-size:2.2rem; margin-bottom:0.8rem; }
.section-intro p { color:var(--gray2); font-size:0.9rem; font-weight:300; }
.awards-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.award-card { background:var(--card); border:1px solid rgba(255,255,255,0.05); padding:2.5rem; position:relative; overflow:hidden; transition:border-color 0.3s,transform 0.3s; }
.award-card:hover { border-color:rgba(201,168,76,0.3); transform:translateY(-4px); }
.award-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(to right,var(--gold),var(--gold-light),transparent); }
.award-card.congressional::before { background:linear-gradient(to right,#1a3a6e,#4a7aae,transparent); }
.award-badge { display:inline-block; font-size:0.62rem; letter-spacing:2px; text-transform:uppercase; padding:0.3rem 0.8rem; margin-bottom:1.2rem; font-weight:600; }
.badge-gold { background:rgba(201,168,76,0.15); color:var(--gold); border:1px solid rgba(201,168,76,0.3); }
.badge-blue { background:rgba(26,58,110,0.3); color:#6a9ade; border:1px solid rgba(74,122,174,0.3); }
.badge-green { background:rgba(0,100,50,0.2); color:#4ada8a; border:1px solid rgba(0,150,80,0.3); }
.award-icon-sm { font-size:2rem; margin-bottom:1rem; display:block; }
.award-card h3 { font-family:'Playfair Display',serif; font-size:1.2rem; line-height:1.3; margin-bottom:0.4rem; }
.award-card .awrd-org { font-size:0.78rem; color:var(--gold); letter-spacing:1px; margin-bottom:0.8rem; }
.award-card p { color:var(--gray2); font-size:0.82rem; line-height:1.7; }
