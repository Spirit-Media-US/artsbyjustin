---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const [siteSettings, shopItems] = await Promise.all([
  sanityClient.fetch(`*[_type == "siteSettings"][0]`),
  sanityClient.fetch(`
    *[_type == "artwork" && available == true] | order(order asc, _createdAt desc) {
      _id,
      title,
      image,
      medium,
      year,
      price
    }
  `)
]);

const settings = siteSettings || {};
const { artistName = 'Justin' } = settings;
---
<Layout title="Shop" description="Limited edition prints and original works available for purchase.">
  <Nav slot="nav" />

  <section class="shop-hero reveal">
    <h1>Shop</h1>
    <p>Limited edition prints, originals, and curated works available for purchase.</p>
  </section>

  <section class="shop-grid-section">
    <div class="shop-inner">
      {shopItems && shopItems.length > 0 ? (
        <div class="shop-grid">
          {shopItems.map((item: any, i: number) => (
            <article class="shop-card reveal" style={`animation-delay:${(i%4)*0.07}s`}>
              <div class="shop-image">
                {item.image && item.image.asset
                  ? <img 
                      src={urlFor(item.image).width(400).height(500).fit('crop').url()} 
                      alt={item.title}
                      loading="lazy"
                    />
                  : <div class="img-placeholder"><span>{item.title}</span></div>
                }
              </div>
              <div class="shop-meta">
                <h3>{item.title}</h3>
                <p class="meta-info">
                  {[item.medium, item.year].filter(Boolean).join(' · ')}
                </p>
                {item.price && (
                  <p class="price">${item.price.toFixed(2)}</p>
                )}
                <button class="btn-add-to-cart" data-item-id={item._id}>
                  Add to Cart
                </button>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="no-items reveal" style="text-align:center; padding:4rem 2rem; color:#8B7355;">
          <p>Shop coming soon. Check back for available works.</p>
        </div>
      )}
    </div>
  </section>

  <section class="shipping-info">
    <div class="shipping-inner">
      <h2 class="reveal">Shop Information</h2>
      <div class="info-grid reveal">
        <div class="info-block">
          <h4>Shipping</h4>
          <p>Orders ship within 1-2 weeks. Domestic and international shipping available. Tracking provided with all orders.</p>
        </div>
        <div class="info-block">
          <h4>Returns</h4>
          <p>If you're not satisfied with your purchase, we offer a 30-day return window. Contact us to arrange returns.</p>
        </div>
        <div class="info-block">
          <h4>Originals</h4>
          <p>Interested in acquiring an original work? Contact Justin directly for availability, pricing, and custom requests.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cartBtns = document.querySelectorAll('.btn-add-to-cart');
    
    cartBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const itemId = btn.dataset.itemId;
        // TODO: Integrate with Shopify, Stripe, or custom cart
        alert(`Added to cart: ${itemId}`);
      });
    });
  });
</script>

<style>
  .shop-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 5rem; text-align:center; }
  .shop-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .shop-hero p { color:#8B7355; max-width:600px; margin:0 auto; font-size:1.0625rem; line-height:1.75; }
  .shop-grid-section { background:#F7F4EE; padding:5rem 2.5rem 6rem; }
  .shop-inner { max-width:1280px; margin:0 auto; }
  .shop-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; }
  .shop-card { }
  .shop-image { background:#EDE8DF; height:400px; overflow:hidden; border:1px solid rgba(139,115,85,0.15); }
  .shop-image img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; }
  .shop-card:hover .shop-image img { transform:scale(1.03); }
  .shop-meta { padding:1rem 0; }
  .shop-meta h3 { font-family:'Playfair Display',serif; font-size:0.95rem; font-weight:600; margin-bottom:0.25rem; }
  .meta-info { font-size:0.75rem; color:#8B7355; margin-bottom:0.5rem; }
  .price { font-family:'DM Sans',sans-serif; font-weight:600; color:#C4622D; font-size:1rem; margin-bottom:0.75rem; }
  .btn-add-to-cart { display:block; width:100%; background:#C4622D; color:#F7F4EE; border:none; padding:0.75rem; font-size:0.75rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; cursor:pointer; transition:background 0.25s; }
  .btn-add-to-cart:hover { background:#A8501F; }
  .img-placeholder { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px dashed #8B7355; color:#8B7355; font-size:0.8rem; text-align:center; padding:2rem; width:100%; height:400px; font-family:'Playfair Display',serif; box-sizing:border-box; }
  .img-placeholder span { font-size:1rem; color:#3D3D3A; font-weight:600; }
  .no-items { color:#8B7355; }
  .shipping-info { max-width:1280px; margin:0 auto; padding:6rem 2.5rem; }
  .shipping-inner { }
  .shipping-info h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; text-align:center; margin-bottom:3rem; }
  .info-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:3rem; }
  .info-block h4 { font-family:'Playfair Display',serif; font-size:1.125rem; font-weight:600; margin-bottom:0.75rem; color:#1A1A18; }
  .info-block p { color:#3D3D3A; font-size:0.95rem; line-height:1.7; }
  @media (max-width:1024px) { 
    .shop-grid { grid-template-columns:repeat(3,1fr); gap:1.5rem; }
    .info-grid { grid-template-columns:repeat(2,1fr); }
    .shop-grid-section { padding:4rem 2.5rem 5rem; }
  }
  @media (max-width:768px) { 
    .shop-grid { grid-template-columns:repeat(2,1fr); gap:1.5rem; }
    .info-grid { grid-template-columns:1fr; }
  }
  @media (max-width:640px) { 
    .shop-hero,.shop-grid-section,.shipping-info { padding-inline:1.5rem; } 
    .shop-grid { grid-template-columns:1fr; }
  }
</style>
