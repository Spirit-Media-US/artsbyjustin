function getBadge(item) {
  if (item.type === 'print') return '<span class="shop-badge badge-print">Fine Art Print</span>';
  if (item.type === 'resin') return '<span class="shop-badge badge-resin">Resin Art</span>';
  if (item.sold) return '<span class="shop-badge badge-sold">Sold</span>';
  return '<span class="shop-badge badge-available">Available</span>';
}

function getActions(item) {
  if (item.type === 'print') return `<a class="btn-gold" href="${ETSY}" target="_blank" rel="noopener">Shop Prints on Etsy →</a>`;
  if (item.sold) return `<button class="btn-ghost" onclick="openInquiry(${item.id},'general')">Inquire About Similar Work →</button>`;
  if (item.type === 'resin') return `<a class="btn-gold" href="${ETSY}" target="_blank" rel="noopener">Request Pricing on Etsy →</a>`;
  return `<a class="btn-gold" href="${ETSY}" target="_blank" rel="noopener">Buy on Etsy — ${item.price} →</a>
          <button class="btn-ghost" onclick="openInquiry(${item.id},'print')">Inquire About a Print</button>`;
}

function buildShop(filter) {
  const grid = document.getElementById('shopGrid');
  grid.innerHTML = '';
  const items = filter === 'all' ? shopItems : shopItems.filter(i => i.type === filter);
  items.forEach(item => {
    const card = document.createElement('div');
    card.className = 'shop-card';
    card.innerHTML = `
      <div class="shop-img">
        <div class="shop-img-bg" style="background:url('${item.img}') center top/cover no-repeat;"></div>
        ${getBadge(item)}
      </div>
      <div class="shop-info">
        <div class="shop-cat">${item.series}</div>
        <div class="shop-title">${item.title}</div>
        <div class="shop-meta">${item.medium} · ${item.size} · ${item.year}</div>
        <div class="shop-price ${item.sold ? 'sold' : ''}">${item.sold ? 'Sold' : item.price}</div>
      </div>
      <div class="shop-actions">${getActions(item)}</div>`;
    grid.appendChild(card);
  });
  document.getElementById('printsSection').style.display = (filter === 'original') ? 'none' : '';
}

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    buildShop(btn.dataset.filter);
  });
});

// Inquiry modal
let currentInquiryId = null;
function openInquiry(id, type) {
  currentInquiryId = id;
  document.getElementById('inqForm').style.display = '';
  document.getElementById('inqSuccess').style.display = 'none';
  const sel = document.getElementById('inqType');
  const titleEl = document.getElementById('inqTitle');
  if (type === 'print') { sel.value = 'print'; titleEl.textContent = 'Inquire About a Print'; }
  else { sel.value = 'general'; titleEl.textContent = 'Get in Touch'; }
  const f = document.getElementById('inqFor');
  if (id) {
    const item = shopItems.find(x => x.id === id);
    f.style.display = '';
    f.innerHTML = `Regarding: <strong>${item.title}</strong> · ${item.medium}`;
  } else f.style.display = 'none';
  document.getElementById('inquiryModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeInquiry() {
  document.getElementById('inquiryModal').classList.remove('open');
  document.body.style.overflow = '';
}
document.getElementById('inquiryModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeInquiry(); });
document.getElementById('inqCloseBtn').addEventListener('click', closeInquiry);
document.getElementById('inqSubmitBtn').addEventListener('click', () => {
  if (!document.getElementById('inqFirst').value.trim() || !document.getElementById('inqEmail').value.trim()) {
    alert('Please fill in your name and email.'); return;
  }
  document.getElementById('inqForm').style.display = 'none';
  document.getElementById('inqSuccess').style.display = 'block';
  setTimeout(closeInquiry, 3500);
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeInquiry(); });

buildShop('all');
</script>

