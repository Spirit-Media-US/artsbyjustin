---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Shop" description="Own original paintings, fine art prints, and resin art by Justin Keishing — collected around the world.">

  <!-- HERO -->
  <section class="shop-hero">
    <div class="hero-tag"><div class="hero-line"></div><span>The Shop</span><div class="hero-line"></div></div>
    <h1>Own a Piece of<br/><em>the Story.</em></h1>
    <p>Original paintings, fine art prints, and resin pieces — each one carrying the energy, purpose, and boldness that defines Arts by Justin. Find yours today.</p>
  </section>

  <!-- FILTER -->
  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="original">Originals</button>
    <button class="filter-btn" data-filter="print">Prints</button>
    <button class="filter-btn" data-filter="resin">Resin Art</button>
  </div>

  <!-- SHOP GRID -->
  <section class="shop-section">
    <div class="shop-grid" id="shopGrid"></div>
  </section>

  <!-- PRINTS SECTION -->
  <section class="prints-section" id="printsSection">
    <div class="section-header">
      <p class="label">Fine Art Prints</p>
      <div class="bar"></div>
      <h2>Take the Art Home —<br/><em>Any Painting. Two Sizes.</em></h2>
      <p>Can't get enough of a piece? Every artwork in Justin's collection is available as a high-quality fine art print. Choose your size, order instantly, and it ships straight to your door.</p>
    </div>
    <div class="prints-grid">
      <div class="print-card">
        <div class="print-img" style="background:url('https://res.cloudinary.com/dztkjeayt/image/upload/v1772764073/7F349BFB-3ACD-47D6-9AC5-56FFEB7345B9_jlvpk9.jpg') center top/cover no-repeat;"></div>
        <div class="print-info">
          <div>
            <div class="print-size">11 × 17"</div>
            <div class="print-dims">Standard Fine Art Print</div>
            <div class="print-features">
              <div class="print-feature">Premium archival paper</div>
              <div class="print-feature">Vibrant, fade-resistant inks</div>
              <div class="print-feature">Ships in protective tube</div>
              <div class="print-feature">Ready to frame</div>
            </div>
          </div>
          <div>
            <div class="print-price-row">
              <div class="print-price">$89</div>
              <div class="print-note">Free shipping<br/>within the US</div>
            </div>
            <a class="btn-gold" href="https://artsbyjustin.etsy.com" target="_blank" rel="noopener">Buy Now — $89 →</a>
          </div>
        </div>
      </div>
      <div class="print-card">
        <div class="print-img" style="background:url('https://res.cloudinary.com/dztkjeayt/image/upload/v1772764073/A34786D0-51D9-4524-B2A2-C2723CECE012_ugjrze.jpg') center top/cover no-repeat;"></div>
        <div class="print-info">
          <div>
            <div class="print-size">12 × 18"</div>
            <div class="print-dims">Large Fine Art Print</div>
            <div class="print-features">
              <div class="print-feature">Premium archival paper</div>
              <div class="print-feature">Vibrant, fade-resistant inks</div>
              <div class="print-feature">Ships in protective tube</div>
              <div class="print-feature">Ready to frame</div>
            </div>
          </div>
          <div>
            <div class="print-price-row">
              <div class="print-price">$99</div>
              <div class="print-note">Free shipping<br/>within the US</div>
            </div>
            <a class="btn-gold" href="https://artsbyjustin.etsy.com" target="_blank" rel="noopener">Buy Now — $99 →</a>
          </div>
        </div>
      </div>
    </div>
    <div class="custom-size-band">
      <div>
        <h3>Need a Different Size?</h3>
        <p>Want something bigger for a feature wall, or smaller for a tight space? Justin can accommodate custom print sizes on request — just reach out via the shop.</p>
      </div>
      <a class="btn-ghost" href="https://artsbyjustin.etsy.com" target="_blank" rel="noopener">Visit the Etsy Shop →</a>
    </div>
  </section>

  <!-- INQUIRY MODAL -->
  <div class="inquiry-modal" id="inquiryModal">
    <div class="inq-box" id="inqBox">
      <button class="inq-close" id="inqCloseBtn">✕</button>
      <div id="inqForm">
        <div class="inq-title" id="inqTitle">Get in Touch</div>
        <div class="inq-sub">Justin will respond within 2–3 business days</div>
        <div class="inq-for" id="inqFor" style="display:none;"></div>
        <div class="form-grid">
          <div class="form-row"><label>First Name</label><input type="text" id="inqFirst" placeholder="Jordan"/></div>
          <div class="form-row"><label>Last Name</label><input type="text" id="inqLast" placeholder="Smith"/></div>
        </div>
        <div class="form-row"><label>Email</label><input type="email" id="inqEmail" placeholder="you@example.com"/></div>
        <div class="form-row">
          <label>I'm interested in…</label>
          <select id="inqType">
            <option value="purchase">Purchasing an original</option>
            <option value="print">Custom print size</option>
            <option value="general">General inquiry</option>
          </select>
        </div>
        <div class="form-row"><label>Message</label><textarea id="inqMsg" placeholder="Tell Justin what you're looking for…"></textarea></div>
        <button class="btn-gold btn-wide" id="inqSubmitBtn">Send Message →</button>
      </div>
      <div class="form-success" id="inqSuccess">
        <div class="check">✓</div>
        <h3>Message Sent</h3>
        <p>Thank you! Justin will be in touch within 2–3 business days.</p>
      </div>
    </div>
  </div>

</Layout>

