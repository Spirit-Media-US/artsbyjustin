function getBadge(item){
  if(item.type==='print') return '<span class="shop-badge badge-print">Fine Art Print</span>';
  if(item.type==='resin') return '<span class="shop-badge badge-resin">Resin Art</span>';
  if(item.sold) return '<span class="shop-badge badge-sold">Sold</span>';
  return '<span class="shop-badge badge-available">Available</span>';
}

function getActions(item){
  if(item.type==='print'){
    return `<a class="btn-gold" href="${ETSY}" target="_blank">Shop Prints on Etsy â</a>`;
  }
  if(item.sold){
    return `<button class="btn-ghost" onclick="openInquiry(${item.id},'general')">Inquire About Similar Work â</button>`;
  }
  if(item.type==='resin'){
    return `<a class="btn-gold" href="${ETSY}" target="_blank">Request Pricing on Etsy â</a>`;
  }
  return `<a class="btn-gold" href="${ETSY}" target="_blank">Buy on Etsy â ${item.price} â</a>
          <button class="btn-ghost" onclick="openInquiry(${item.id},'print')">Inquire About a Print</button>`;
}

function buildShop(filter){
  const grid = document.getElementById('shopGrid');
  grid.innerHTML = '';
  const items = filter==='all' ? shopItems : shopItems.filter(i=>i.type===filter);
  items.forEach(item=>{
    const card = document.createElement('div');
    card.className = 'shop-card';
    card.innerHTML = `
      <div class="shop-img">
        <div class="shop-img-bg" style="background:url('${item.img}') center top/cover no-repeat;"></div>
        ${getBadge(item)}
      </div>
      <div class="shop-info">
        <div class="shop-cat">${item.series}</div>
        <div class="shop-title">${item.title}</div>
        <div class="shop-meta">${item.medium} Â· ${item.size} Â· ${item.year}</div>
        <div class="shop-price ${item.sold?'sold':''}">${item.sold?'Sold':item.price}</div>
      </div>
      <div class="shop-actions">${getActions(item)}</div>`;
    grid.appendChild(card);
  });
  document.getElementById('printsSection').style.display = (filter==='original') ? 'none' : '';
}

function filterShop(f, btn){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  buildShop(f);
}

function openInquiry(id, type){
  document.getElementById('inqForm').style.display='';
  document.getElementById('inqSuccess').style.display='none';
  const sel = document.getElementById('inqType');
  const titleEl = document.getElementById('inqTitle');
  if(type==='print'){sel.value='print';titleEl.textContent='Inquire About a Print';}
  else{sel.value='general';titleEl.textContent='Get in Touch';}
  const f = document.getElementById('inqFor');
  if(id){
    const item = shopItems.find(x=>x.id===id);
    f.style.display='';
    f.innerHTML=`Regarding: <strong>${item.title}</strong> Â· ${item.medium}, ${item.size}`;
  } else f.style.display='none';
  document.getElementById('inquiryModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeInquiry(e){
  if(e&&e.target!==document.getElementById('inquiryModal'))return;
  document.getElementById('inquiryModal').classList.remove('open');
  document.body.style.overflow='';
}
function submitInquiry(){
  if(!document.getElementById('inqFirst').value.trim()||!document.getElementById('inqEmail').value.trim()){alert('Please fill in your name and email.');return;}
  document.getElementById('inqForm').style.display='none';
  document.getElementById('inqSuccess').style.display='block';
  setTimeout(()=>{document.getElementById('inquiryModal').classList.remove('open');document.body.style.overflow='';},3500);
}

window.addEventListener('scroll',()=>document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>60));
function toggleMobile(){document.getElementById('mobileMenu').classList.toggle('open');}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){document.getElementById('inquiryModal').classList.remove('open');document.body.style.overflow='';}});
const ro=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:0.15});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

buildShop('all');
</script>
