---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Contact" description="Get in touch with Justin — for general inquiries, commissions, press, or collaborations.">
  <Nav slot="nav" />
  <section class="contact-hero reveal">
    <div class="hero-inner">
      <p class="eyebrow">Contact</p>
      <h1>Let's Talk</h1>
      <p class="sub">Whether you have a question about a painting, a commission idea, or just want to say hello — Justin reads every message himself.</p>
    </div>
  </section>
  <section class="contact-body">
    <div class="contact-grid">
      <div class="contact-info reveal">
        <div class="info-block"><h3>General Inquiries</h3><p>Questions about existing work, availability, or anything else.</p><a href="mailto:hello@artsbyjustin.com" class="email-link">hello@artsbyjustin.com</a></div>
        <div class="info-block"><h3>Commissions</h3><p>Ready to discuss a custom piece? Use the form below, or visit the <a href="/commissions">Commissions page</a> for full process details.</p></div>
        <div class="info-block"><h3>Press & Collaboration</h3><p>For editorial, exhibition, or partnership inquiries, please note "Press" in your message.</p></div>
        <div class="info-block"><h3>Response Time</h3><p>Justin typically responds within 3–5 business days.</p></div>
        <div class="social-links">
          <p class="social-label">Follow the Work</p>
          <a href="https://instagram.com/artsbyjustin" target="_blank" rel="noopener" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            @artsbyjustin
          </a>
        </div>
      </div>
      <div class="contact-form reveal">
        <h2>Send a Message</h2>
        <!--
          REPLACE with GoHighLevel embed code.
          GHL: Settings → Forms → "Arts by Justin — General Contact" → Embed
          Tag: source:abj-contact  |  Pipeline: General Inquiry
        -->
        <div class="form-placeholder">
          <p>GoHighLevel General Contact Form</p>
          <p class="form-note">Tag: <code>source:abj-contact</code> · Pipeline: General Inquiry</p>
        </div>
        <div class="newsletter-section">
          <h3>Stay in the Loop</h3>
          <p>New work, prints, and upcoming shows — sent occasionally, never spammy.</p>
          <!-- Tag: source:abj-newsletter  Pipeline: Newsletter -->
          <div class="form-placeholder small"><p>GHL Newsletter Signup</p><p class="form-note">Tag: <code>source:abj-newsletter</code></p></div>
        </div>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
<style>
  .contact-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 5rem; }
  .hero-inner { max-width:1280px; margin:0 auto; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1rem; }
  .contact-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1rem; }
  .sub { color:#8B7355; max-width:520px; line-height:1.75; font-size:1.0625rem; }
  .contact-body { max-width:1280px; margin:0 auto; padding:5rem 2.5rem 6rem; }
  .contact-grid { display:grid; grid-template-columns:340px 1fr; gap:5rem; align-items:start; }
  .contact-info { display:flex; flex-direction:column; gap:2.5rem; }
  .info-block h3 { font-family:'Playfair Display',serif; font-size:1rem; font-weight:600; margin-bottom:0.5rem; }
  .info-block p { font-size:0.9rem; color:#3D3D3A; line-height:1.65; }
  .info-block a { color:#C4622D; }
  .info-block a:hover { text-decoration:underline; }
  .email-link { display:inline-block; margin-top:0.5rem; font-size:0.875rem; color:#C4622D !important; }
  .social-label { font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:#8B7355; margin-bottom:0.75rem; }
  .social-link { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; color:#3D3D3A; transition:color 0.2s; }
  .social-link:hover { color:#C4622D; }
  .contact-form h2 { font-family:'Playfair Display',serif; font-size:1.75rem; font-weight:600; letter-spacing:-0.02em; margin-bottom:2rem; padding-bottom:1rem; border-bottom:1px solid rgba(26,26,24,0.1); }
  .form-placeholder { background:#EDE8DF; border:2px dashed #8B7355; padding:3rem 2rem; text-align:center; color:#8B7355; margin-bottom:2.5rem; }
  .form-placeholder.small { padding:2rem; margin-bottom:0; }
  .form-placeholder p { margin-bottom:0.5rem; font-weight:500; }
  .form-note { font-size:0.8rem; }
  .form-note code { background:rgba(26,26,24,0.08); padding:0.1rem 0.4rem; font-family:monospace; font-size:0.75rem; }
  .newsletter-section { padding-top:2.5rem; border-top:1px solid rgba(26,26,24,0.08); }
  .newsletter-section h3 { font-family:'Playfair Display',serif; font-size:1.25rem; font-weight:600; margin-bottom:0.5rem; }
  .newsletter-section p { color:#3D3D3A; font-size:0.9rem; line-height:1.6; margin-bottom:1.5rem; }
  @media (max-width:1024px) { .contact-grid { grid-template-columns:1fr; gap:3rem; } }
  @media (max-width:640px) { .contact-hero,.contact-body { padding-inline:1.5rem; } }
</style>
