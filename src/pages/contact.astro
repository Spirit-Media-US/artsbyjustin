---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sanityClient } from '../lib/sanity.ts';

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const settings = siteSettings || {};
const { 
  artistName = 'Justin', 
  email = '', 
  phone = '', 
  instagramUrl = '', 
  facebookUrl = '',
  tagline = 'Mixed media artist. Original works, commissions, and prints.'
} = settings;
---
<Layout title="Contact" description={`Get in touch with ${artistName} about commissions, inquiries, and collaborations.`}>
  <Nav slot="nav" />

  <section class="contact-hero reveal">
    <h1>Get In Touch</h1>
    <p>Have a question or interested in working together? We'd love to hear from you.</p>
  </section>

  <section class="contact-section">
    <div class="contact-grid">
      <div class="contact-form reveal">
        <h2>Send a Message</h2>
        <form id="contact-form" method="POST">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email-input">Email</label>
            <input type="email" id="email-input" name="email" required />
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" required />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" required></textarea>
          </div>
          <button type="submit" class="btn-submit">Send Message</button>
          <div id="form-status" style="margin-top:1rem; font-size:0.9rem;"></div>
        </form>
      </div>

      <div class="contact-info reveal">
        <h2>Connect</h2>
        <div class="info-block">
          <h3>Email</h3>
          {email ? (
            <a href={`mailto:${email}`}>{email}</a>
          ) : (
            <p style="color:#8B7355;">Email address from Sanity</p>
          )}
        </div>
        {phone && (
          <div class="info-block">
            <h3>Phone</h3>
            <a href={`tel:${phone}`}>{phone}</a>
          </div>
        )}
        <div class="info-block">
          <h3>Follow</h3>
          <div class="social-links">
            {instagramUrl && (
              <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="social-link">Instagram</a>
            )}
            {facebookUrl && (
              <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="social-link">Facebook</a>
            )}
          </div>
        </div>
        <div class="info-block">
          <h3>Commission Inquiries</h3>
          <p>For custom work, use the contact form or email directly. See the <a href="/commissions">commissions page</a> for process details.</p>
        </div>
      </div>
    </div>
  </section>

  <div id="ghl-widget-container" style="display:none;"></div>

  <Footer slot="footer" />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const statusDiv = document.getElementById('form-status');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        statusDiv.textContent = 'Sending...';
        statusDiv.style.color = '#C4622D';
        
        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          if (response.ok) {
            statusDiv.textContent = '✓ Message sent! We\'ll get back to you soon.';
            statusDiv.style.color = '#C4622D';
            form.reset();
          } else {
            throw new Error('Failed to send');
          }
        } catch (err) {
          statusDiv.textContent = '✗ Error sending message. Please try again or email directly.';
          statusDiv.style.color = '#8B7355';
        }
      });
    }
  });
</script>

<style>
  .contact-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 5rem; text-align:center; }
  .contact-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .contact-hero p { color:#8B7355; max-width:600px; margin:0 auto; font-size:1.0625rem; line-height:1.75; }
  .contact-section { max-width:1000px; margin:0 auto; padding:6rem 2.5rem; }
  .contact-grid { display:grid; grid-template-columns:1.5fr 1fr; gap:4rem; }
  .contact-form h2,.contact-info h2 { font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:600; margin-bottom:2rem; color:#1A1A18; }
  .form-group { margin-bottom:1.5rem; }
  .form-group label { display:block; margin-bottom:0.5rem; color:#1A1A18; font-size:0.9rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; }
  .form-group input,.form-group textarea { width:100%; padding:0.75rem; border:1px solid rgba(26,26,24,0.15); background:#FAFAF8; font-family:'DM Sans',sans-serif; font-size:0.95rem; transition:border 0.2s; }
  .form-group input:focus,.form-group textarea:focus { outline:none; border-color:#C4622D; }
  .form-group textarea { resize:vertical; }
  .btn-submit { width:100%; background:#C4622D; color:#F7F4EE; padding:0.875rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; border:none; cursor:pointer; transition:background 0.25s; }
  .btn-submit:hover { background:#A8501F; }
  .contact-info { }
  .info-block { margin-bottom:2.5rem; }
  .info-block h3 { font-family:'Playfair Display',serif; font-size:1rem; font-weight:600; margin-bottom:0.75rem; color:#1A1A18; }
  .info-block p { color:#3D3D3A; font-size:0.95rem; line-height:1.7; }
  .info-block a { color:#C4622D; text-decoration:none; transition:color 0.2s; }
  .info-block a:hover { color:#A8501F; }
  .social-links { display:flex; flex-direction:column; gap:0.5rem; }
  .social-link { font-size:0.9rem; }
  @media (max-width:1024px) { 
    .contact-grid { grid-template-columns:1fr; gap:3rem; }
  }
  @media (max-width:640px) { 
    .contact-hero,.contact-section { padding-inline:1.5rem; }
  }
</style>
