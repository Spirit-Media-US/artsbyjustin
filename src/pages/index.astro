---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const [siteSettings, featuredWorks] = await Promise.all([
  sanityClient.fetch(`*[_type == "siteSettings"][0]`),
  sanityClient.fetch(`
    *[_type == "artwork" && featured == true] | order(order asc, _createdAt desc)[0...6] {
      _id,
      title,
      image,
      medium,
      year,
      available
    }
  `)
]);

const settings = siteSettings || {};
const { artistName = 'Justin', tagline = '', heroImage } = settings;
---
<Layout title="Home" description={tagline || "Contemporary paintings and mixed media by Justin"}>
  <Nav slot="nav" />
  <section class="hero reveal">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="eyebrow">Artist & Maker</p>
        <h1>{artistName}</h1>
        {tagline && <p class="tagline">{tagline}</p>}
        <div class="hero-cta">
          <a href="/portfolio" class="btn-primary">View Portfolio</a>
          <a href="/commissions" class="btn-secondary">Commission Work</a>
        </div>
      </div>
      <div class="hero-image">
        {heroImage && heroImage.asset 
          ? <img 
              src={urlFor(heroImage).width(600).height(700).url()} 
              alt={artistName}
              loading="eager"
            />
          : <div class="img-placeholder">
              <span>Hero image</span>
              <p>Featured work from Sanity</p>
            </div>
        }
      </div>
    </div>
  </section>

  {featuredWorks && featuredWorks.length > 0 && (
    <section class="featured-works">
      <div class="featured-inner">
        <div class="featured-header reveal">
          <h2>Selected Works</h2>
          <a href="/portfolio" class="view-all">View all →</a>
        </div>
        <div class="works-grid">
          {featuredWorks.map((work: any, i: number) => (
            <article class="work-card reveal" style={`animation-delay:${(i%3)*0.07}s`}>
              <div class="work-image">
                {work.image && work.image.asset
                  ? <img 
                      src={urlFor(work.image).width(400).height(500).fit('crop').url()} 
                      alt={work.title}
                      loading="lazy"
                    />
                  : <div class="img-placeholder"><span>{work.title}</span></div>
                }
              </div>
              <div class="work-meta">
                <h3>{work.title}</h3>
                <p class="meta-info">
                  {[work.medium, work.year].filter(Boolean).join(' · ')}
                </p>
                <span class={`badge ${work.available ? 'available' : 'sold'}`}>
                  {work.available ? 'Available' : 'Sold'}
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="cta-section">
    <div class="cta-inner reveal">
      <h2>Interested in Commissioning?</h2>
      <p>Justin accepts a limited number of custom projects each season. Explore the full commission process or send an inquiry.</p>
      <a href="/commissions" class="btn-primary">Start an Inquiry</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .hero { padding:8rem 2.5rem 6rem; max-width:1400px; margin:0 auto; }
  .hero-inner { display:grid; grid-template-columns:1fr 550px; gap:4rem; align-items:center; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1rem; }
  .hero-content h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1.5rem; line-height:1.1; }
  .tagline { font-size:1.25rem; color:#3D3D3A; line-height:1.65; margin-bottom:2rem; max-width:480px; }
  .hero-cta { display:flex; gap:1rem; flex-wrap:wrap; margin-top:2.5rem; }
  .btn-primary { display:inline-block; background:#C4622D; color:#F7F4EE; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s; }
  .btn-primary:hover { background:#A8501F; }
  .btn-secondary { display:inline-block; border:1px solid #3D3D3A; color:#3D3D3A; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:all 0.25s; }
  .btn-secondary:hover { background:#3D3D3A; color:#F7F4EE; }
  .hero-image { position:relative; }
  .hero-image img { width:100%; height:auto; display:block; }
  .img-placeholder { background:#EDE8DF; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px dashed #8B7355; color:#8B7355; font-size:0.8rem; text-align:center; padding:2rem; min-height:400px; font-family:'Playfair Display',serif; }
  .img-placeholder span { font-size:1rem; color:#3D3D3A; font-weight:600; }
  .featured-works { background:#F7F4EE; padding:6rem 2.5rem; }
  .featured-inner { max-width:1280px; margin:0 auto; }
  .featured-header { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:3rem; padding-bottom:1.5rem; border-bottom:1px solid rgba(26,26,24,0.1); }
  .featured-header h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; }
  .view-all { color:#C4622D; font-size:0.9rem; letter-spacing:0.06em; text-decoration:none; transition:gap 0.2s; }
  .view-all:hover { gap:0.75rem; }
  .works-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2.5rem; }
  .work-card { cursor:pointer; }
  .work-image { background:#EDE8DF; height:400px; overflow:hidden; border:1px solid rgba(139,115,85,0.15); }
  .work-image img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; }
  .work-card:hover .work-image img { transform:scale(1.03); }
  .work-meta { padding:1rem 0; }
  .work-meta h3 { font-family:'Playfair Display',serif; font-size:1.125rem; font-weight:600; margin-bottom:0.25rem; }
  .meta-info { font-size:0.8rem; color:#8B7355; margin-bottom:0.5rem; }
  .badge { font-size:0.7rem; letter-spacing:0.08em; text-transform:uppercase; padding:0.3rem 0.75rem; display:inline-block; }
  .badge.available { background:rgba(196,98,45,0.1); color:#C4622D; }
  .badge.sold { background:rgba(26,26,24,0.07); color:#8B7355; }
  .cta-section { background:#1A1A18; color:#EDE8DF; padding:6rem 2.5rem; text-align:center; }
  .cta-inner { max-width:760px; margin:0 auto; }
  .cta-section h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .cta-section p { color:#8B7355; font-size:1.0625rem; line-height:1.75; margin-bottom:2rem; }
  @media (max-width:1024px) { 
    .hero-inner { grid-template-columns:1fr; gap:3rem; } 
    .works-grid { grid-template-columns:repeat(2,1fr); }
  }
  @media (max-width:640px) { 
    .hero,.featured-works,.cta-section { padding-inline:1.5rem; } 
    .works-grid { grid-template-columns:1fr; }
    .featured-header { flex-direction:column; align-items:flex-start; }
  }
</style>
