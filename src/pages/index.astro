---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Home">
  <Nav slot="nav" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">Mixed Media Artist</p>
      <h1>Art that<br /><em>holds something</em><br />true.</h1>
      <p class="hero-sub">Original paintings, mixed media works, and handcrafted prints — each piece made to invite stillness and reflection.</p>
      <div class="hero-cta">
        <a href="/portfolio" class="btn-primary">View Portfolio</a>
        <a href="/commissions" class="btn-ghost">Commission a Piece</a>
      </div>
    </div>
    <div class="hero-image">
      <!-- REPLACE: upload to assets.artsbyjustin.com/artwork/hero-main.jpg then swap src below -->
      <div class="img-placeholder tall">
        <span>Hero Image</span>
        <p>assets.artsbyjustin.com/artwork/hero-main.jpg</p>
      </div>
      <div class="hero-accent-block"></div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-strip">
    <div class="marquee-track">
      <span>Oil & Acrylic</span><span>·</span><span>Watercolor</span><span>·</span>
      <span>Mixed Media</span><span>·</span><span>Collage</span><span>·</span>
      <span>Charcoal</span><span>·</span><span>Ink</span><span>·</span>
      <span>Original Prints</span><span>·</span><span>Commissions</span><span>·</span>
      <span>Oil & Acrylic</span><span>·</span><span>Watercolor</span><span>·</span>
      <span>Mixed Media</span><span>·</span><span>Collage</span><span>·</span>
      <span>Charcoal</span><span>·</span><span>Ink</span><span>·</span>
      <span>Original Prints</span><span>·</span><span>Commissions</span><span>·</span>
    </div>
  </div>

  <!-- SELECTED WORKS -->
  <section class="selected-works">
    <div class="section-header reveal">
      <h2>Selected Works</h2>
      <a href="/portfolio" class="see-all">See all →</a>
    </div>
    <div class="works-grid">
      {[
        { title: 'Untitled Study No. 1', medium: 'Oil on canvas', year: '2024', size: 'tall' },
        { title: 'Layered Light', medium: 'Mixed media', year: '2024', size: 'wide' },
        { title: 'Between', medium: 'Watercolor & ink', year: '2023', size: 'square' },
        { title: 'Still Ground', medium: 'Acrylic & collage', year: '2024', size: 'square' },
        { title: 'Remnant', medium: 'Charcoal & oil', year: '2023', size: 'wide' },
      ].map((work, i) => (
        <article class={`work-card ${work.size} reveal`} style={`animation-delay:${i*0.08}s`}>
          <div class="work-img-placeholder"><span>{work.title}</span></div>
          <div class="work-meta"><h3>{work.title}</h3><p>{work.medium}, {work.year}</p></div>
        </article>
      ))}
    </div>
  </section>

  <!-- ABOUT STRIP -->
  <section class="about-strip reveal">
    <div class="about-strip-inner">
      <div class="about-strip-text">
        <p class="eyebrow">About the Artist</p>
        <h2>The work begins before the brush touches the surface.</h2>
        <p>Justin works across oil, watercolor, and mixed media — finding the image in the layering, the accident, the revision. Each piece is a conversation between intention and discovery.</p>
        <a href="/about" class="btn-outline">Read More</a>
      </div>
      <div class="about-strip-img">
        <!-- REPLACE: assets.artsbyjustin.com/press/justin-portrait.jpg -->
        <div class="img-placeholder square"><span>Artist Photo</span><p>assets.artsbyjustin.com/press/justin-portrait.jpg</p></div>
      </div>
    </div>
  </section>

  <!-- COMMISSION CTA -->
  <section class="commission-cta reveal">
    <div class="cta-inner">
      <p class="eyebrow">Custom Work</p>
      <h2>Commission an original piece.</h2>
      <p>Whether it's a portrait, a landscape, or something entirely your own — let's make something together. Justin takes a limited number of commissions each season.</p>
      <a href="/commissions" class="btn-primary">Start a Commission</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .hero { min-height:100svh; display:grid; grid-template-columns:1fr 1fr; align-items:center; padding:7rem 2.5rem 4rem; max-width:1280px; margin:0 auto; gap:5rem; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1.25rem; }
  .hero-text h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5.5rem); font-weight:700; line-height:1.08; letter-spacing:-0.02em; margin-bottom:1.75rem; }
  .hero-text h1 em { font-style:italic; color:#C4622D; }
  .hero-sub { font-size:1.0625rem; color:#3D3D3A; max-width:400px; margin-bottom:2.5rem; line-height:1.75; }
  .hero-cta { display:flex; gap:1rem; flex-wrap:wrap; }
  .btn-primary { display:inline-block; background:#C4622D; color:#F7F4EE; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s,transform 0.2s; }
  .btn-primary:hover { background:#A8501F; transform:translateY(-1px); }
  .btn-ghost { display:inline-block; border:1px solid #1A1A18; color:#1A1A18; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s,color 0.25s; }
  .btn-ghost:hover { background:#1A1A18; color:#F7F4EE; }
  .btn-outline { display:inline-block; border:1px solid #C4622D; color:#C4622D; padding:0.75rem 1.75rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s,color 0.25s; }
  .btn-outline:hover { background:#C4622D; color:#F7F4EE; }
  .hero-image { position:relative; height:600px; }
  .img-placeholder { background:#EDE8DF; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px dashed #8B7355; color:#8B7355; font-size:0.8rem; text-align:center; padding:1.5rem; }
  .img-placeholder.tall { width:100%; height:100%; }
  .img-placeholder.square { width:100%; height:400px; }
  .img-placeholder span { font-family:'Playfair Display',serif; font-size:1rem; color:#3D3D3A; font-weight:600; }
  .hero-accent-block { position:absolute; bottom:-1.5rem; right:-1.5rem; width:200px; height:200px; background:#C4622D; opacity:0.12; z-index:-1; }
  .marquee-strip { border-top:1px solid rgba(26,26,24,0.1); border-bottom:1px solid rgba(26,26,24,0.1); background:#EDE8DF; padding:1rem 0; overflow:hidden; }
  .marquee-track { display:flex; gap:2rem; width:max-content; animation:scroll-marquee 30s linear infinite; font-size:0.75rem; letter-spacing:0.12em; text-transform:uppercase; color:#8B7355; align-items:center; }
  @keyframes scroll-marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
  .selected-works { max-width:1280px; margin:6rem auto; padding:0 2.5rem; }
  .section-header { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:3rem; border-bottom:1px solid rgba(26,26,24,0.1); padding-bottom:1.25rem; }
  .section-header h2 { font-family:'Playfair Display',serif; font-size:clamp(1.75rem,3vw,2.5rem); font-weight:600; letter-spacing:-0.02em; }
  .see-all { font-size:0.875rem; letter-spacing:0.05em; color:#C4622D; text-transform:uppercase; transition:letter-spacing 0.2s; }
  .see-all:hover { letter-spacing:0.1em; }
  .works-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
  .work-card { cursor:pointer; }
  .work-img-placeholder { background:#EDE8DF; display:flex; align-items:flex-end; padding:1rem; border:1px solid rgba(139,115,85,0.15); transition:filter 0.3s; color:#8B7355; font-family:'Playfair Display',serif; font-size:0.875rem; font-style:italic; }
  .work-card:hover .work-img-placeholder { filter:brightness(0.96); }
  .work-card.tall .work-img-placeholder { height:480px; }
  .work-card.wide .work-img-placeholder { height:260px; }
  .work-card.square .work-img-placeholder { height:320px; }
  .work-card.tall { grid-row:span 2; }
  .work-card.wide { grid-column:span 2; }
  .work-meta { padding:0.875rem 0 0; }
  .work-meta h3 { font-family:'Playfair Display',serif; font-size:1rem; font-weight:600; margin-bottom:0.25rem; }
  .work-meta p { font-size:0.8rem; color:#8B7355; }
  .about-strip { background:#1A1A18; color:#EDE8DF; padding:5rem 2.5rem; margin-top:3rem; }
  .about-strip-inner { max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 400px; gap:5rem; align-items:center; }
  .about-strip .eyebrow { color:#C4622D; }
  .about-strip-text h2 { font-family:'Playfair Display',serif; font-size:clamp(1.75rem,3vw,2.75rem); font-weight:600; line-height:1.2; margin:1rem 0; letter-spacing:-0.02em; }
  .about-strip-text p { color:#8B7355; max-width:480px; margin-bottom:2rem; line-height:1.75; font-size:0.9375rem; }
  .commission-cta { max-width:1280px; margin:6rem auto; padding:4rem 2.5rem; border:1px solid rgba(26,26,24,0.1); text-align:center; position:relative; overflow:hidden; }
  .commission-cta::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 60% 50%,rgba(196,98,45,0.05) 0%,transparent 70%); }
  .cta-inner { position:relative; }
  .commission-cta .eyebrow { margin-bottom:1rem; }
  .commission-cta h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; margin-bottom:1rem; }
  .commission-cta p { color:#3D3D3A; max-width:560px; margin:0 auto 2.5rem; line-height:1.75; }
  @media (max-width:1024px) {
    .hero { grid-template-columns:1fr; min-height:auto; padding-top:10rem; }
    .hero-image { height:380px; }
    .works-grid { grid-template-columns:repeat(2,1fr); }
    .work-card.wide { grid-column:span 1; }
    .about-strip-inner { grid-template-columns:1fr; }
  }
  @media (max-width:640px) {
    .hero,.selected-works,.commission-cta { padding-inline:1.5rem; }
    .works-grid { grid-template-columns:1fr; }
    .work-card.tall { grid-row:auto; }
  }
</style>
