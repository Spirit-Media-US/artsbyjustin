---
import Layout from '../layouts/Layout.astro';
import { getArtworks } from '../lib/sanity';
import { urlFor } from '../lib/sanity';
import { SEED_ARTWORKS } from '../data/artworks';

let rawArtworks: any[] = [];
try { rawArtworks = await getArtworks(); } catch (e) {}
if (!rawArtworks || rawArtworks.length === 0) rawArtworks = SEED_ARTWORKS as any[];

const artworks = rawArtworks.map((a: any) => ({
  _id: a._id,
  title: a.title || '',
  medium: a.medium || '',
  year: a.year ? String(a.year) : '',
  category: a.category || '',
  colorGradient: a.colorGradient || a.fallback || '',
  imageUrl: a.imageUrl || (a.image ? urlFor(a.image).width(900).url() : ''),
}));

const CATEGORIES = ['Sports & Motion', 'Portraits & Identity', 'Faith & Spirit', 'Abstract & Mixed Media'];
const totalCount = artworks.length;
---
<Layout title="Portfolio" description="The full collection — original acrylic and mixed media works by Justin Keishing. Filter by theme and explore every canvas.">

  <!-- HERO -->
  <section class="port-hero">
    <div class="port-eyebrow">
      <div class="port-line"></div>
      <span>The Collection</span>
    </div>
    <h1>Every Canvas<br/><em>Tells a Story.</em></h1>
    <p>Browse the full body of work — from sports legends to spiritual journeys. <span class="count-badge" id="countBadge">{totalCount} Works</span></p>
  </section>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <button class="filter-btn active" data-cat="all">All</button>
    {CATEGORIES.map(cat => (
      <button class="filter-btn" data-cat={cat}>{cat}</button>
    ))}
  </div>

  <!-- GRID -->
  <section class="grid-section">
    <div class="art-grid" id="artGrid">
      {artworks.map((a) => (
        <div class="art-card" data-category={a.category}>
          <div
            class="art-bg"
            style={a.imageUrl
              ? `background:url('${a.imageUrl}') center/cover no-repeat`
              : `background:${a.colorGradient || 'linear-gradient(135deg,#111,#222)'}`}
          ></div>
          {a.category && <div class="art-tag">{a.category}</div>}
          <div class="art-info">
            <h3>{a.title}</h3>
            <p>{[a.medium, a.year].filter(Boolean).join(' · ')}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="empty-msg" id="emptyMsg" style="display:none;">No works in this category yet.</p>
  </section>

  <!-- CTA -->
  <section class="port-cta">
    <h2>Like What You See?</h2>
    <p>Originals, prints, and commissions available. Get in touch to start a conversation.</p>
    <div class="port-cta-btns">
      <a href="/commissions" class="btn-gold">Start a Commission →</a>
      <a href="/shop" class="btn-ghost">Shop the Collection</a>
    </div>
  </section>

</Layout>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.art-card');
  const countBadge = document.getElementById('countBadge');
  const emptyMsg = document.getElementById('emptyMsg');

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = (btn as HTMLElement).dataset.cat;
      let visible = 0;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.category === cat;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (countBadge) countBadge.textContent = `${visible} Work${visible !== 1 ? 's' : ''}`;
      if (emptyMsg) emptyMsg.style.display = visible === 0 ? '' : 'none';
    });
  });
</script>

<style>
  /* HERO */
  .port-hero {
    background: linear-gradient(135deg, #080808, #0f0800, #080808);
    padding: 10rem 3rem 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .port-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.07), transparent 65%);
  }
  .port-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .port-line { width: 30px; height: 1px; background: var(--gold); }
  .port-eyebrow span {
    font-size: 0.68rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
  }
  .port-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    line-height: 1.05;
  }
  .port-hero h1 em { color: var(--gold); font-style: italic; }
  .port-hero p {
    color: var(--gray2);
    font-size: 1.0625rem;
    line-height: 1.75;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .count-badge {
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold);
    font-size: 0.7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
  }

  /* FILTER */
  .filter-bar {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 2rem 3rem;
    background: var(--black);
    position: sticky;
    top: 61px;
    z-index: 100;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .filter-btn {
    background: transparent;
    color: var(--gray2);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.6rem 1.4rem;
    font-size: 0.72rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    font-family: 'Inter', sans-serif;
  }
  .filter-btn:hover,
  .filter-btn.active {
    background: var(--gold);
    color: var(--black);
    border-color: var(--gold);
    font-weight: 600;
  }

  /* GRID */
  .grid-section { padding: 3rem 3rem 6rem; background: var(--black); }
  .art-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
  }
  .art-card {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    cursor: pointer;
    background: var(--card);
  }
  .art-bg {
    position: absolute;
    inset: 0;
    transition: transform 0.6s, filter 0.4s;
    filter: brightness(0.82);
  }
  .art-card:hover .art-bg {
    transform: scale(1.06);
    filter: brightness(1);
  }
  .art-tag {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    background: rgba(8,8,8,0.75);
    font-size: 0.58rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
    backdrop-filter: blur(4px);
  }
  .art-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.2rem 1.5rem;
    background: linear-gradient(to top, rgba(0,0,0,0.92), transparent);
    transform: translateY(100%);
    transition: transform 0.35s;
  }
  .art-card:hover .art-info { transform: translateY(0); }
  .art-info h3 {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
    color: var(--white);
  }
  .art-info p {
    font-size: 0.68rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray2);
  }
  .empty-msg {
    text-align: center;
    color: var(--gray);
    padding: 4rem 0;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  /* CTA */
  .port-cta {
    padding: 7rem 3rem;
    background: linear-gradient(135deg, #0d0800, #150900);
    text-align: center;
  }
  .port-cta h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .port-cta p {
    color: var(--gray2);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }
  .port-cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-gold {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    padding: 0.875rem 2rem;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    transition: background 0.25s;
    text-decoration: none;
  }
  .btn-gold:hover { background: var(--gold-light); }
  .btn-ghost {
    display: inline-block;
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--white);
    padding: 0.875rem 2rem;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    transition: all 0.25s;
    text-decoration: none;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .art-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .port-hero, .grid-section, .port-cta { padding-inline: 1.5rem; }
    .filter-bar { padding: 1.5rem; gap: 0.4rem; top: 57px; }
    .art-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .art-grid { gap: 2px; }
    .port-cta-btns { flex-direction: column; align-items: center; }
    .btn-gold, .btn-ghost { width: 100%; text-align: center; }
  }
</style>
