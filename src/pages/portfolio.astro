  .hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,5vw,4.5rem);line-height:1.1;margin-bottom:1rem;animation:fadeUp 0.8s 0.4s both;}
  .hero h1 em{color:var(--gold);font-style:italic;}
  .hero p{color:var(--gray2);max-width:560px;margin:0 auto;font-size:0.95rem;line-height:1.9;font-weight:300;animation:fadeUp 0.8s 0.6s both;}
