<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Portfolio 芒聙聰 Arts by Justin</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{--black:#080808;--dark:#111;--card:#161616;--gold:#c9a84c;--gold-light:#e8c97a;--white:#f0f0f0;--gray:#777;--gray2:#aaa;}
html{scroll-behavior:smooth;}
body{background:var(--black);color:var(--white);font-family:'Inter',sans-serif;overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:1.2rem 3rem;display:flex;justify-content:space-between;align-items:center;background:rgba(8,8,8,0.95);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.04);transition:padding 0.3s;}
nav.scrolled{padding:0.8rem 3rem;border-bottom-color:rgba(201,168,76,0.15);}
.logo{font-family:'Playfair Display',serif;font-size:1.3rem;letter-spacing:2px;}
.logo span{color:var(--gold);}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{color:var(--gray2);text-decoration:none;font-size:0.78rem;letter-spacing:1.5px;text-transform:uppercase;transition:color 0.3s;}
.nav-links a:hover,.nav-links a.active{color:var(--gold);}
.nav-cta{background:var(--gold);color:var(--black);padding:0.55rem 1.4rem;font-size:0.75rem;letter-spacing:1.5px;text-transform:uppercase;font-weight:700;border:none;cursor:pointer;transition:background 0.3s;}
.nav-cta:hover{background:var(--gold-light);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;}
.hamburger span{display:block;width:24px;height:2px;background:var(--white);transition:all 0.3s;}
.mobile-menu{display:none;position:fixed;inset:0;top:60px;background:rgba(8,8,8,0.98);z-index:190;flex-direction:column;align-items:center;justify-content:center;gap:2rem;}
.mobile-menu.open{display:flex;}
.mobile-menu a{color:var(--gray2);text-decoration:none;font-size:1.1rem;letter-spacing:3px;text-transform:uppercase;}

/* HERO */
.hero{padding:9rem 3rem 5rem;text-align:center;background:linear-gradient(135deg,#080808,#0f0800,#080808);position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(201,168,76,0.07),transparent 65%);}
.hero-tag{display:inline-flex;align-items:center;gap:0.8rem;margin-bottom:1.5rem;opacity:0;animation:fadeUp 0.8s 0.2s forwards;}
.hero-line{width:30px;height:1px;background:var(--gold);}
.hero-tag span{font-size:0.68rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,5vw,4.5rem);line-height:1.1;margin-bottom:1rem;opacity:0;animation:fadeUp 0.8s 0.4s forwards;}
.hero h1 em{color:var(--gold);font-style:italic;}
.hero p{color:var(--gray2);max-width:560px;margin:0 auto 2.5rem;font-size:0.95rem;line-height:1.9;font-weight:300;opacity:0;animation:fadeUp 0.8s 0.6s forwards;}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}

/* FILTER */
.filter-bar{display:flex;justify-content:center;gap:0.5rem;flex-wrap:wrap;padding:0 3rem 4rem;}
.filter-btn{background:transparent;color:var(--gray2);border:1px solid rgba(255,255,255,0.08);padding:0.6rem 1.4rem;font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.3s;font-family:'Inter',sans-serif;}
.filter-btn:hover,.filter-btn.active{background:var(--gold);color:var(--black);border-color:var(--gold);font-weight:600;}

/* CINEMATIC */
.cinematic{position:relative;height:90vh;overflow:hidden;background:var(--black);}
.cinema-slide{position:absolute;inset:0;opacity:0;transition:opacity 0.9s ease;pointer-events:none;}
.cinema-slide.active{opacity:1;pointer-events:all;}
.cinema-bg{position:absolute;inset:0;background-size:cover;background-position:center top;filter:brightness(0.55);transform:scale(1.05);transition:transform 8s ease;}
.cinema-slide.active .cinema-bg{transform:scale(1);}
.cinema-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(8,8,8,0.95) 0%,rgba(8,8,8,0.4) 50%,rgba(8,8,8,0.05) 100%);}
.cinema-content{position:absolute;bottom:0;left:0;top:0;display:flex;flex-direction:column;justify-content:flex-end;padding:4rem 5rem;max-width:580px;z-index:2;}
.cinema-category{font-size:0.65rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:0.8rem;display:flex;align-items:center;gap:0.8rem;}
.cinema-category::before{content:'';width:20px;height:1px;background:var(--gold);}
.cinema-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.5rem);line-height:1.1;margin-bottom:0.8rem;}
.cinema-meta{color:var(--gray2);font-size:0.82rem;letter-spacing:1px;margin-bottom:1rem;}
.cinema-desc{color:var(--gray2);font-size:0.88rem;line-height:1.8;margin-bottom:2rem;font-weight:300;max-width:420px;}
.cinema-actions{display:flex;gap:1rem;align-items:center;flex-wrap:wrap;}
.btn-gold{background:var(--gold);color:var(--black);padding:0.75rem 1.8rem;font-size:0.75rem;letter-spacing:2px;text-transform:uppercase;font-weight:700;border:none;cursor:pointer;transition:all 0.3s;}
.btn-gold:hover{background:var(--gold-light);}
.btn-ghost{background:transparent;color:var(--white);padding:0.75rem 1.8rem;font-size:0.75rem;letter-spacing:2px;text-transform:uppercase;border:1px solid rgba(255,255,255,0.2);cursor:pointer;transition:all 0.3s;}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold);}
.sold-badge{background:rgba(180,30,30,0.9);color:#fff;font-size:0.65rem;letter-spacing:2px;text-transform:uppercase;padding:0.35rem 0.8rem;font-weight:600;}
.cinema-fullview{position:absolute;top:1.5rem;right:7rem;z-index:10;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:var(--white);padding:0.5rem 1rem;font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;cursor:pointer;backdrop-filter:blur(10px);transition:all 0.3s;}
.cinema-fullview:hover{background:var(--gold);border-color:var(--gold);color:var(--black);}
.cinema-nav{position:absolute;right:3rem;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:1rem;z-index:10;}
.cinema-arrow{width:48px;height:48px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:var(--white);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.3s;font-size:1rem;backdrop-filter:blur(10px);}
.cinema-arrow:hover{background:var(--gold);border-color:var(--gold);color:var(--black);}
.cinema-progress{position:absolute;bottom:0;left:0;right:0;height:2px;background:rgba(255,255,255,0.06);z-index:10;}
.cinema-progress-fill{height:100%;background:var(--gold);width:0;transition:width 0.1s linear;}
.cinema-counter{position:absolute;right:3rem;bottom:3rem;z-index:10;text-align:right;}
.counter-current{font-family:'Playfair Display',serif;font-size:3rem;color:var(--gold);line-height:1;}
.counter-total{font-size:0.7rem;letter-spacing:2px;color:var(--gray);text-transform:uppercase;}

/* THUMBS */
.thumb-strip{background:#0a0a0a;padding:1.5rem 3rem;display:flex;gap:3px;overflow-x:auto;scrollbar-width:none;}
.thumb-strip::-webkit-scrollbar{display:none;}
.thumb{width:80px;height:60px;flex-shrink:0;cursor:pointer;position:relative;overflow:hidden;opacity:0.4;transition:opacity 0.3s,transform 0.3s;}
.thumb:hover,.thumb.active{opacity:1;transform:scaleY(1.05);}
.thumb-bg{width:100%;height:100%;background-size:cover;background-position:center top;}
.thumb-sold{position:absolute;inset:0;background:rgba(180,30,30,0.6);display:flex;align-items:center;justify-content:center;font-size:0.5rem;letter-spacing:1px;text-transform:uppercase;color:#fff;}

/* STATS */
.stats-bar{background:#0c0900;border-top:1px solid rgba(201,168,76,0.1);border-bottom:1px solid rgba(201,168,76,0.1);padding:3rem;display:grid;grid-template-columns:repeat(4,1fr);text-align:center;gap:2rem;}
.stat-num{font-family:'Playfair Display',serif;font-size:2.5rem;color:var(--gold);line-height:1;margin-bottom:0.3rem;}
.stat-label{font-size:0.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--gray2);}

/* GRID */
.grid-section{padding:6rem 3rem;background:var(--dark);}
.grid-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;flex-wrap:wrap;gap:1rem;}
.grid-header h2{font-family:'Playfair Display',serif;font-size:2rem;}
.label{font-size:0.68rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:0.5rem;}
.bar{width:50px;height:2px;background:var(--gold);margin-bottom:1.5rem;}
.portfolio-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.grid-item{position:relative;aspect-ratio:3/4;overflow:hidden;cursor:pointer;}
.grid-item-bg{width:100%;height:100%;background-size:cover;background-position:center top;transition:transform 0.6s,filter 0.4s;filter:brightness(0.8);}
.grid-item:hover .grid-item-bg{transform:scale(1.06);filter:brightness(1);}
.grid-item-info{position:absolute;bottom:0;left:0;right:0;padding:1.2rem;background:linear-gradient(to top,rgba(0,0,0,0.92),transparent);transform:translateY(100%);transition:transform 0.35s;}
.grid-item:hover .grid-item-info{transform:translateY(0);}
.grid-item-info h3{font-family:'Playfair Display',serif;font-size:0.9rem;margin-bottom:0.2rem;}
.grid-item-info p{font-size:0.65rem;letter-spacing:1px;text-transform:uppercase;color:var(--gray2);}
.grid-sold{position:absolute;top:0.8rem;right:0.8rem;background:rgba(180,30,30,0.9);color:#fff;font-size:0.55rem;letter-spacing:1.5px;text-transform:uppercase;padding:0.25rem 0.6rem;}
.grid-cat{position:absolute;top:0.8rem;left:0.8rem;background:rgba(8,8,8,0.7);color:var(--gold);font-size:0.55rem;letter-spacing:1.5px;text-transform:uppercase;padding:0.25rem 0.6rem;border:1px solid rgba(201,168,76,0.3);}
.grid-zoom{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.3s;}
.grid-item:hover .grid-zoom{opacity:1;}
.grid-zoom-icon{width:44px;height:44px;border:1px solid rgba(255,255,255,0.5);display:flex;align-items:center;justify-content:center;font-size:1.2rem;backdrop-filter:blur(4px);background:rgba(0,0,0,0.3);}

/* SERIES */
.series{padding:6rem 3rem;background:var(--black);}
.series-intro{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;margin-bottom:4rem;}
.series-intro h2{font-family:'Playfair Display',serif;font-size:2.2rem;margin-bottom:1rem;}
.series-intro p{color:var(--gray2);font-size:0.93rem;line-height:1.9;font-weight:300;}
.series-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;}
.series-item{position:relative;aspect-ratio:1;overflow:hidden;cursor:pointer;}
.series-item-bg{width:100%;height:100%;background-size:cover;background-position:center top;transition:transform 0.6s,filter 0.4s;filter:brightness(0.75);}
.series-item:hover .series-item-bg{transform:scale(1.06);filter:brightness(1);}
.series-item-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85),transparent 50%);display:flex;align-items:flex-end;padding:1.2rem;}
.series-item-overlay h3{font-family:'Playfair Display',serif;font-size:0.95rem;}
.series-item-overlay p{font-size:0.65rem;letter-spacing:1px;text-transform:uppercase;color:var(--gray2);margin-top:0.2rem;}

/* COLLECTORS SLIDESHOW */
.collectors{padding:6rem 3rem;background:var(--black);overflow:hidden;}
.collectors-header{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;margin-bottom:3.5rem;}
.collectors-header h2{font-family:'Playfair Display',serif;font-size:2.2rem;line-height:1.2;}
.collectors-header h2 em{color:var(--gold);font-style:italic;}
.collectors-sub{color:var(--gray2);font-size:0.93rem;line-height:1.9;font-weight:300;align-self:end;}
/* Infinite scroll ticker rows */
.ticker-wrap{display:flex;flex-direction:column;gap:3px;margin-bottom:3rem;}
.ticker-row{display:flex;gap:3px;overflow:hidden;}
.ticker-track{display:flex;gap:3px;animation:ticker 40s linear infinite;}
.ticker-track.reverse{animation-direction:reverse;animation-duration:50s;}
.ticker-cell{width:160px;height:160px;flex-shrink:0;position:relative;overflow:hidden;cursor:pointer;}
.ticker-cell img{width:100%;height:100%;object-fit:cover;filter:brightness(0.85);transition:filter 0.3s,transform 0.4s;}
.ticker-cell:hover img{filter:brightness(1);transform:scale(1.08);}
.ticker-overlay{position:absolute;inset:0;background:rgba(0,0,0,0);transition:background 0.3s;display:flex;align-items:center;justify-content:center;}
.ticker-cell:hover .ticker-overlay{background:rgba(201,168,76,0.15);}
.ticker-gold{position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transition:transform 0.3s;}
.ticker-cell:hover .ticker-gold{transform:scaleX(1);}
@keyframes ticker{from{transform:translateX(0);}to{transform:translateX(-50%)}}
.ticker-wrap:hover .ticker-track{animation-play-state:paused;}

/* BEYOND THE CANVAS */
.beyond{padding:6rem 3rem;background:var(--dark);}
.beyond-header{margin-bottom:3.5rem;}
.beyond-header h2{font-family:'Playfair Display',serif;font-size:2.2rem;margin-bottom:0.8rem;}
.beyond-header h2 em{color:var(--gold);font-style:italic;}
.beyond-header p{color:var(--gray2);font-size:0.93rem;line-height:1.9;font-weight:300;max-width:600px;}
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;}
.project-card{position:relative;overflow:hidden;cursor:pointer;}
.project-card.wide{grid-column:span 2;aspect-ratio:16/9;}
.project-card.sq{aspect-ratio:1;}
.project-bg{width:100%;height:100%;min-height:260px;background-size:cover;background-position:center;filter:brightness(0.7);transition:filter 0.4s,transform 0.6s;}
.project-card:hover .project-bg{filter:brightness(1);transform:scale(1.04);}
.project-info{position:absolute;bottom:0;left:0;right:0;padding:1.5rem;background:linear-gradient(to top,rgba(0,0,0,0.92),transparent);}
.project-type{font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem;}
.project-info h3{font-family:'Playfair Display',serif;font-size:1.1rem;margin-bottom:0.2rem;}
.project-info p{font-size:0.72rem;color:var(--gray2);}
.beyond-cta{text-align:center;padding:3rem;background:rgba(201,168,76,0.04);border:1px solid rgba(201,168,76,0.1);margin-top:3px;}
.beyond-cta h3{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.5rem;}
.beyond-cta p{color:var(--gray2);font-size:0.88rem;margin-bottom:1.5rem;}

/* COMMISSION */
.comm-band{padding:6rem 3rem;background:linear-gradient(135deg,#0d0800,#150900);display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;}
.comm-band h2{font-family:'Playfair Display',serif;font-size:2.2rem;margin-bottom:1rem;line-height:1.2;}
.comm-band h2 em{color:var(--gold);font-style:italic;}
.comm-band p{color:var(--gray2);font-size:0.93rem;line-height:1.9;font-weight:300;margin-bottom:2rem;}
.comm-steps-mini{display:flex;flex-direction:column;gap:1rem;}
.comm-step-mini{display:flex;align-items:center;gap:1rem;}
.step-dot{width:32px;height:32px;border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:0.65rem;color:var(--gold);flex-shrink:0;}
.comm-step-mini p{color:var(--gray2);font-size:0.85rem;}

/* LIGHTBOX */
.lightbox{position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0);pointer-events:none;transition:background 0.4s;display:flex;align-items:center;justify-content:center;}
.lightbox.open{background:rgba(0,0,0,0.94);pointer-events:all;}
.lb-inner{display:flex;max-width:1100px;width:95%;max-height:90vh;opacity:0;transform:scale(0.95);transition:all 0.4s;background:var(--card);}
.lightbox.open .lb-inner{opacity:1;transform:scale(1);}
.lb-art{flex:1;min-height:500px;background-size:cover;background-position:center top;position:relative;}
.lb-art-sold{position:absolute;top:1rem;left:1rem;background:rgba(180,30,30,0.9);color:#fff;font-size:0.62rem;letter-spacing:2px;text-transform:uppercase;padding:0.3rem 0.7rem;}
.lb-info{width:320px;flex-shrink:0;padding:2.5rem;display:flex;flex-direction:column;justify-content:space-between;overflow-y:auto;}
.lb-cat{font-size:0.62rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;display:flex;align-items:center;gap:0.6rem;}
.lb-cat::before{content:'';width:16px;height:1px;background:var(--gold);}
.lb-title{font-family:'Playfair Display',serif;font-size:1.8rem;line-height:1.15;margin-bottom:0.5rem;}
.lb-meta{font-size:0.78rem;color:var(--gray2);margin-bottom:1.2rem;}
.lb-divider{height:1px;background:rgba(255,255,255,0.07);margin:1.2rem 0;}
.lb-desc{font-size:0.88rem;line-height:1.85;color:var(--gray2);font-weight:300;margin-bottom:1.5rem;}
.lb-price-row{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;}
.lb-price{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--gold);}
.lb-price-note{font-size:0.7rem;color:var(--gray);letter-spacing:1px;text-transform:uppercase;}
.lb-actions{display:flex;flex-direction:column;gap:0.7rem;}
.lb-close{position:absolute;top:1rem;right:1rem;width:40px;height:40px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:var(--white);font-size:1.1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s;z-index:10;}
.lb-close:hover{background:var(--gold);color:var(--black);}
.lb-nav{display:flex;gap:0.5rem;margin-bottom:1rem;}
.lb-nav-btn{flex:1;padding:0.5rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:var(--gray2);font-size:0.7rem;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:all 0.3s;}
.lb-nav-btn:hover{border-color:var(--gold);color:var(--gold);}

/* INQUIRY */
.inquiry-modal{position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,0);pointer-events:none;transition:background 0.3s;display:flex;align-items:center;justify-content:center;}
.inquiry-modal.open{background:rgba(0,0,0,0.9);pointer-events:all;}
.inq-box{background:#111;border:1px solid rgba(201,168,76,0.2);max-width:520px;width:92%;padding:3rem;opacity:0;transform:translateY(20px);transition:all 0.4s;position:relative;max-height:90vh;overflow-y:auto;}
.inquiry-modal.open .inq-box{opacity:1;transform:translateY(0);}
.inq-title{font-family:'Playfair Display',serif;font-size:1.6rem;margin-bottom:0.4rem;}
.inq-sub{font-size:0.8rem;color:var(--gray2);letter-spacing:1px;margin-bottom:2rem;}
.inq-for{background:rgba(201,168,76,0.06);border-left:2px solid var(--gold);padding:0.8rem 1rem;margin-bottom:2rem;font-size:0.85rem;color:var(--gray2);}
.form-row{margin-bottom:1.2rem;}
.form-row label{display:block;font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;color:var(--gray2);margin-bottom:0.5rem;}
.form-row input,.form-row textarea,.form-row select{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:var(--white);padding:0.75rem 1rem;font-family:'Inter',sans-serif;font-size:0.88rem;outline:none;transition:border-color 0.3s;}
.form-row input:focus,.form-row textarea:focus,.form-row select:focus{border-color:var(--gold);}
.form-row textarea{min-height:100px;resize:vertical;}
.form-row select option{background:#111;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.inq-close{position:absolute;top:1rem;right:1rem;width:36px;height:36px;background:transparent;border:1px solid rgba(255,255,255,0.1);color:var(--gray2);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.inq-close:hover{border-color:var(--gold);color:var(--gold);}
.form-success{text-align:center;padding:2rem 0;display:none;}
.form-success .check{font-size:3rem;margin-bottom:1rem;}
.form-success h3{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.5rem;}
.form-success p{color:var(--gray2);font-size:0.88rem;line-height:1.7;}

/* FOOTER */
footer{background:#040404;padding:3rem;display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,0.05);flex-wrap:wrap;gap:1.5rem;}
.f-logo{font-family:'Playfair Display',serif;font-size:1.1rem;}
.f-logo span{color:var(--gold);}
.f-links{display:flex;gap:2rem;flex-wrap:wrap;}
.f-links a{color:var(--gray);text-decoration:none;font-size:0.75rem;letter-spacing:1px;text-transform:uppercase;transition:color 0.3s;}
.f-links a:hover{color:var(--gold);}
