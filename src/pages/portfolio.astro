---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Portfolio" description="The full collection — bold acrylic paintings, mixed media works, resin art, murals, and 3D pieces by Justin Keishing. Each one a story made with purpose.">

<!-- HERO -->
<section class="hero">
  <div class="hero-tag"><div class="hero-line"></div><span>The Collection</span><div class="hero-line"></div></div>
  <h1>Art That<br/><em>Moves You.</em></h1>
  <p>Bold acrylic paintings, mixed media works, resin art, murals, and 3D pieces — each one a story, each one made with purpose.</p>
</section>

<!-- FILTER -->
<div class="filter-bar">
  <button class="filter-btn active" data-cat="all">All Works</button>
  <button class="filter-btn" data-cat="chase">Chase Your Dreams</button>
  <button class="filter-btn" data-cat="resin">Resin Art</button>
  <button class="filter-btn" data-cat="mural">Murals</button>
  <button class="filter-btn" data-cat="mixed">Mixed Media</button>
</div>

<!-- CINEMATIC VIEWER -->
<div class="cinematic" id="cinematicViewer">
  <button class="cinema-fullview" id="fullViewBtn">⤢ Full View</button>
  <div class="cinema-nav">
    <div class="cinema-arrow" id="prevBtn">↑</div>
    <div class="cinema-arrow" id="nextBtn">↓</div>
  </div>
  <div class="cinema-counter">
    <div class="counter-current" id="counterCurrent">01</div>
    <div class="counter-total" id="counterTotal">of 20</div>
  </div>
  <div class="cinema-progress"><div class="cinema-progress-fill" id="progressFill"></div></div>
</div>
<div class="thumb-strip" id="thumbStrip"></div>

<!-- STATS BAR -->
<div class="stats-bar">
  <div><div class="stat-num">460+</div><div class="stat-label">Original Works</div></div>
  <div><div class="stat-num">5</div><div class="stat-label">Series & Collections</div></div>
  <div><div class="stat-num">3</div><div class="stat-label">Countries Exhibited</div></div>
  <div><div class="stat-num">∞</div><div class="stat-label">Stories Told</div></div>
</div>

<!-- PORTFOLIO GRID -->
<section class="grid-section">
  <div class="grid-header reveal">
    <div><p class="label">Complete Collection</p><div class="bar"></div><h2>All Works</h2></div>
    <div style="display:flex;align-items:center;gap:1.5rem;">
      <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.72rem;color:var(--gray2);letter-spacing:1px;"><div style="width:10px;height:10px;background:rgba(180,30,30,0.9);"></div>Sold</div>
      <div style="display:flex;align-items:center;gap:0.5rem;font-size:0.72rem;color:var(--gray2);letter-spacing:1px;"><div style="width:10px;height:10px;border:1px solid var(--gold);"></div>Available</div>
    </div>
  </div>
  <div class="portfolio-grid" id="portfolioGrid"></div>
</section>

<!-- CHASE YOUR DREAMS SERIES -->
<section class="series" id="chaseSeries">
  <div class="series-intro reveal">
    <div>
      <p class="label">Featured Series</p><div class="bar"></div>
      <h2>Chase Your Dreams</h2>
      <p>Justin's most celebrated series — bold acrylic paintings of athletes, musicians, and dreamers, each in grayscale with an explosive burst of color representing their purpose.</p>
      <p style="margin-top:1rem;color:var(--gray2);font-size:0.93rem;line-height:1.9;font-weight:300;">"This series was born out of my own ambition to chase my dreams no matter what happens."</p>
      <button class="btn-gold" style="margin-top:1.5rem;" id="shopChaseBtn">Shop This Series →</button>
    </div>
    <div id="seriesHeroImg" style="aspect-ratio:3/4;background-size:cover;background-position:center top;position:relative;">
      <div style="position:absolute;bottom:1rem;right:1rem;font-size:0.65rem;letter-spacing:2px;color:rgba(255,255,255,0.5);text-transform:uppercase;">SOAR · Acrylic on Canvas</div>
    </div>
  </div>
  <div class="series-grid" id="chaseGrid"></div>
</section>

<!-- COLLECTORS WALL -->
<section class="collectors" id="collectorsWall">
  <div class="collectors-header reveal">
    <div>
      <p class="label">Happy Collectors</p><div class="bar"></div>
      <h2>A Wall of<br/><em>Happy Collectors.</em></h2>
    </div>
    <p class="collectors-sub">From exhibitions to living rooms — these are the people who've welcomed Justin's work into their lives. Every face tells a story. Every painting found its person.</p>
  </div>
  <div class="ticker-wrap" id="tickerWrap"></div>
  <div style="text-align:center;margin-top:2rem;">
    <p style="font-size:0.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--gray2);margin-bottom:1.2rem;">Own a Justin Keishing original? We'd love to feature you.</p>
    <button class="btn-ghost" id="submitPhotoBtn">Submit Your Photo →</button>
  </div>
</section>

<!-- BEYOND THE CANVAS -->
<section class="beyond" id="beyondCanvas">
  <div class="beyond-header reveal">
    <p class="label">Large-Scale & Commercial</p><div class="bar"></div>
    <h2>Beyond the Canvas —<br/><em>Built to Last.</em></h2>
    <p>From full salon interiors to sculptural concrete installations, Justin brings the same fearless creativity to large-scale and commercial projects. These aren't decorations — they're experiences.</p>
  </div>
  <div class="projects-grid" id="projectsGrid"></div>
  <div class="beyond-cta reveal">
    <h3>Have a Space That Needs a Statement?</h3>
    <p>Justin works with businesses, interior designers, and property developers on bespoke large-scale installations.</p>
    <button class="btn-gold" id="muralInquiryBtn">Discuss Your Project →</button>
  </div>
</section>

<!-- COMMISSION BAND -->
<section class="comm-band reveal">
  <div>
    <p class="label">Custom Work</p><div class="bar"></div>
    <h2>Don't See What<br/>You're Looking For?<br/><em>Let's Create It.</em></h2>
    <p>Justin accepts a limited number of commissions each year. Every commissioned piece is personal, intentional, and built around your story.</p>
    <a href="/commissions" class="btn-gold" style="display:inline-block;text-decoration:none;">Start a Commission →</a>
  </div>
  <div>
    <p class="label" style="margin-bottom:1.5rem;">How It Works</p>
    <div class="comm-steps-mini">
      <div class="comm-step-mini"><div class="step-dot">01</div><p>Share your idea, vision, or the story you want told</p></div>
      <div class="comm-step-mini"><div class="step-dot">02</div><p>Justin consults on concept, size, medium &amp; timeline</p></div>
      <div class="comm-step-mini"><div class="step-dot">03</div><p>Your one-of-a-kind piece is created with care &amp; purpose</p></div>
      <div class="comm-step-mini"><div class="step-dot">04</div><p>Delivered ready to hang — and to move people</p></div>
    </div>
  </div>
</section>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox">
  <div class="lb-inner" id="lbInner">
    <div class="lb-art" id="lbArt"><button class="lb-close" id="lbCloseBtn">✕</button></div>
    <div class="lb-info">
      <div>
        <div class="lb-nav">
          <button class="lb-nav-btn" id="lbPrevBtn">← Prev</button>
          <button class="lb-nav-btn" id="lbNextBtn">Next →</button>
        </div>
        <div class="lb-cat" id="lbCat"></div>
        <div class="lb-title" id="lbTitle"></div>
        <div class="lb-meta" id="lbMeta"></div>
        <div class="lb-divider"></div>
        <div class="lb-desc" id="lbDesc"></div>
        <div class="lb-price-row"><div class="lb-price" id="lbPrice"></div><div class="lb-price-note" id="lbPriceNote"></div></div>
      </div>
      <div class="lb-actions" id="lbActions"></div>
    </div>
  </div>
</div>

<!-- INQUIRY MODAL -->
<div class="inquiry-modal" id="inquiryModal">
  <div class="inq-box" id="inqBox">
    <button class="inq-close" id="inqCloseBtn">✕</button>
    <div id="inqForm">
      <div class="inq-title">Get in Touch</div>
      <div class="inq-sub">Justin will respond within 2–3 business days</div>
      <div class="inq-for" id="inqFor" style="display:none;"></div>
      <div class="form-grid">
        <div class="form-row"><label>First Name</label><input type="text" id="inqFirst" placeholder="Jordan"/></div>
        <div class="form-row"><label>Last Name</label><input type="text" id="inqLast" placeholder="Smith"/></div>
      </div>
      <div class="form-row"><label>Email</label><input type="email" id="inqEmail" placeholder="you@example.com"/></div>
      <div class="form-row">
        <label>I'm interested in…</label>
        <select id="inqType">
          <option value="purchase">Purchasing an existing work</option>
          <option value="commission">Commissioning a custom piece</option>
          <option value="mural">Mural / large-scale project</option>
          <option value="general">General inquiry</option>
        </select>
      </div>
      <div class="form-row"><label>Message</label><textarea id="inqMsg" placeholder="Tell Justin about what you're looking for…"></textarea></div>
      <button class="btn-gold" style="width:100%;padding:1rem;" id="inqSubmitBtn">Send Inquiry →</button>
    </div>
    <div class="form-success" id="inqSuccess" style="display:none;">
      <div class="check">✦</div>
      <h3>Message Sent</h3>
      <p>Thank you for reaching out. Justin will be in touch within 2–3 business days.</p>
    </div>
  </div>
</div>

</Layout>

