  {url:'https://cdn.sanity.io/images/oqoqh3p3/production/3a2813d5a3d0e2f1b313d5fa9248c6500eecf4ff-3024x4032.jpg', type:'Concrete & 3D', title:'Architectural Gate', desc:'Sculpted concrete relief, outdoor installation', layout:'sq'},
  {url:'https://cdn.sanity.io/images/oqoqh3p3/production/74b15683413c33987fc1ccc2328d82bf3ffb6a2f-1284x945.jpg', type:'Salon Interior', title:'Client Space · Before & After', desc:'Complete interior art transformation', layout:'wide'},
  {url:'https://cdn.sanity.io/images/oqoqh3p3/production/9dcd8a7ae46001f24244916b732e51ea8175162e-4096x4096.jpg', type:'3D Mixed Media', title:'Custom Relief Installation', desc:'Mixed media, resin & sculptural elements', layout:'sq'},
  {url:'https://cdn.sanity.io/images/oqoqh3p3/production/baeaed0b2287fa4fca8990e874a61ebd9997f8fe-4066x5421.jpg', type:'Concrete / Door', title:'Feature Door', desc:'Sculpted concrete finish, private residence', layout:'sq'},
];

// ── HELPERS ───────────────────────────────────────────────────
function getBg(k){const u=imageMap[k];return u?`url('${u}') center top/cover no-repeat`:'#1a1a1a';}
function getCategoryName(s){return{chase:'Chase Your Dreams Series',resin:'Resin Art',mural:'Murals & Community',mixed:'Mixed Media & 3D Art'}[s]||'Collection';}
function getCategoryShort(s){return{chase:'Chase Dreams',resin:'Resin',mural:'Mural',mixed:'Mixed Media'}[s]||'';}

// ── STATE ─────────────────────────────────────────────────────
let currentSlide=0, filteredArtworks=[...artworks], currentLbIndex=0, lbWorks=[...artworks];
let autoPlay, progressTimer, progressWidth=0;
const SLIDE_DURATION=6000;

// ── CINEMA ────────────────────────────────────────────────────
function buildCinema(works){
  const v=document.getElementById('cinematicViewer');
  v.querySelectorAll('.cinema-slide').forEach(s=>s.remove());
  works.forEach((a,i)=>{
    const s=document.createElement('div');
    s.className='cinema-slide'+(i===0?' active':'');
    s.innerHTML=`<div class="cinema-bg" style="background:${getBg(a.imgKey)};"></div>
    <div class="cinema-overlay"></div>
    <div class="cinema-content">
      <div class="cinema-category">${getCategoryName(a.series)}</div>
      <div class="cinema-title">${a.title}</div>
      <div class="cinema-meta">${a.medium} · ${a.size} · ${a.year}</div>
      <div class="cinema-desc">${a.desc}</div>
      <div class="cinema-actions">${a.sold
        ?`<span class="sold-badge">● Sold</span><button class="btn-ghost" onclick="openInquiry(${a.id},'similar')">Inquire About Similar →</button>`
        :`<button class="btn-gold" onclick="openInquiry(${a.id},'purchase')">Inquire to Purchase →</button><button class="btn-ghost" onclick="openInquiry(null,'commission')">Commission Similar →</button>`
      }</div>
    </div>`;
    v.insertBefore(s, v.querySelector('.cinema-nav'));
  });
  document.getElementById('counterTotal').textContent=`of ${String(works.length).padStart(2,'0')}`;
  updateCounter(0);
}

function buildThumbs(works){
  const strip=document.getElementById('thumbStrip');
  strip.innerHTML='';
  works.forEach((a,i)=>{
    const t=document.createElement('div');
    t.className='thumb'+(i===0?' active':'');
    t.onclick=()=>goToSlide(i);
    t.innerHTML=`<div class="thumb-bg" style="background:${getBg(a.imgKey)};"></div>${a.sold?'<div class="thumb-sold">Sold</div>':''}`;
    strip.appendChild(t);
  });
}

function buildGrid(works){
  const g=document.getElementById('portfolioGrid');
  g.innerHTML='';
  works.forEach(a=>{
    const el=document.createElement('div');
    el.className='grid-item';
    el.onclick=()=>openLightbox(a.id,works);
    el.innerHTML=`<div class="grid-item-bg" style="background:${getBg(a.imgKey)};"></div>
    <div class="grid-cat">${getCategoryShort(a.series)}</div>
    ${a.sold?'<div class="grid-sold">Sold</div>':''}
    <div class="grid-zoom"><div class="grid-zoom-icon">⤢</div></div>
    <div class="grid-item-info"><h3>${a.title}</h3><p>${a.medium} · ${a.year}</p></div>`;
    g.appendChild(el);
  });
}

function buildChaseGrid(){
  const chase=artworks.filter(a=>a.series==='chase');
  const g=document.getElementById('chaseGrid');
  g.innerHTML='';
  chase.slice(0,6).forEach(a=>{
    const el=document.createElement('div');
    el.className='series-item';
    el.onclick=()=>openLightbox(a.id,chase);
    el.innerHTML=`<div class="series-item-bg" style="background:${getBg(a.imgKey)};"></div>
    <div class="series-item-overlay"><div><h3>${a.title}</h3><p>${a.medium} · ${a.year}${a.sold?' · SOLD':''}</p></div></div>`;
    g.appendChild(el);
  });
  const soar=artworks.find(a=>a.title==='SOAR');
  if(soar) document.getElementById('seriesHeroImg').style.background=getBg(soar.imgKey);
}

function buildTicker(){
  const wrap=document.getElementById('tickerWrap');
  wrap.innerHTML='';
  const rowSize=Math.ceil(customerPhotos.length/3);
  const rows=[customerPhotos.slice(0,rowSize),customerPhotos.slice(rowSize,rowSize*2),customerPhotos.slice(rowSize*2)];
  rows.forEach((photos,ri)=>{
    const row=document.createElement('div');
    row.className='ticker-row';
    const track=document.createElement('div');
    track.className='ticker-track'+(ri%2===1?' reverse':'');
    [...photos,...photos].forEach(url=>{
      const cell=document.createElement('div');
      cell.className='ticker-cell';
      cell.innerHTML=`<img src="${url}" loading="lazy" alt="Happy collector"/><div class="ticker-overlay"></div><div class="ticker-gold"></div>`;
      track.appendChild(cell);
    });
    row.appendChild(track);
    wrap.appendChild(row);
  });
}

function buildProjects(){
  const g=document.getElementById('projectsGrid');
  g.innerHTML='';
  projects.forEach(p=>{
    const card=document.createElement('div');
    card.className=`project-card ${p.layout}`;
    card.innerHTML=`<div class="project-bg" style="background:url('${p.url}') center/cover no-repeat;"></div>
    <div class="project-info"><div class="project-type">${p.type}</div><h3>${p.title}</h3><p>${p.desc}</p></div>`;
    g.appendChild(card);
  });
}

// ── SLIDE CONTROLS ────────────────────────────────────────────
function goToSlide(n){
  const slides=document.querySelectorAll('.cinema-slide');
  const thumbs=document.querySelectorAll('.thumb');
  slides[currentSlide]?.classList.remove('active');
  thumbs[currentSlide]?.classList.remove('active');
  currentSlide=(n+slides.length)%slides.length;
  slides[currentSlide]?.classList.add('active');
  thumbs[currentSlide]?.classList.add('active');
  thumbs[currentSlide]?.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
  updateCounter(currentSlide);
  resetProgress();
}
function changeSlide(dir){goToSlide(currentSlide+dir);}
function updateCounter(n){document.getElementById('counterCurrent').textContent=String(n+1).padStart(2,'0');}
function resetProgress(){
  clearInterval(progressTimer); progressWidth=0;
  document.getElementById('progressFill').style.width='0%';
  progressTimer=setInterval(()=>{progressWidth+=100/(SLIDE_DURATION/100);document.getElementById('progressFill').style.width=Math.min(progressWidth,100)+'%';},100);
}
function startAutoPlay(){clearInterval(autoPlay);autoPlay=setInterval(()=>changeSlide(1),SLIDE_DURATION);resetProgress();}

function filterGallery(cat,btn){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  filteredArtworks=cat==='all'?[...artworks]:artworks.filter(a=>a.series===cat);
  currentSlide=0; buildCinema(filteredArtworks); buildThumbs(filteredArtworks); buildGrid(filteredArtworks); startAutoPlay();
}

// ── LIGHTBOX ──────────────────────────────────────────────────
function openLightbox(id,works){
  lbWorks=works||filteredArtworks; currentLbIndex=lbWorks.findIndex(a=>a.id===id);
  renderLightbox(currentLbIndex); document.getElementById('lightbox').classList.add('open'); document.body.style.overflow='hidden';
}
function openLightboxFromSlide(){openLightbox(filteredArtworks[currentSlide].id,filteredArtworks);}
function closeLightbox(e){
  if(e&&e.target!==document.getElementById('lightbox'))return;
  document.getElementById('lightbox').classList.remove('open'); document.body.style.overflow='';
}
function lbNav(dir){currentLbIndex=(currentLbIndex+dir+lbWorks.length)%lbWorks.length;renderLightbox(currentLbIndex);}
function renderLightbox(i){
  const a=lbWorks[i];
  document.getElementById('lbArt').style.background=getBg(a.imgKey);
  document.getElementById('lbCat').textContent=getCategoryName(a.series);
  document.getElementById('lbTitle').textContent=a.title;
  document.getElementById('lbMeta').textContent=`${a.medium} · ${a.size} · ${a.year}`;
  document.getElementById('lbDesc').textContent=a.desc;
  document.getElementById('lbPrice').textContent=a.price;
  document.getElementById('lbPriceNote').textContent=a.sold?'':'Shipping included';
  document.getElementById('lbArt').querySelector('.lb-art-sold')?.remove();
  if(a.sold){const b=document.createElement('div');b.className='lb-art-sold';b.textContent='Sold';document.getElementById('lbArt').appendChild(b);}
  document.getElementById('lbActions').innerHTML=a.sold
    ?`<button class="btn-ghost" onclick="openInquiry(${a.id},'similar')">Inquire About Similar →</button>`
    :`<button class="btn-gold" onclick="openInquiry(${a.id},'purchase')">Inquire to Purchase →</button>
      <button class="btn-ghost" onclick="openInquiry(null,'commission')">Commission Similar →</button>`;
}

// ── INQUIRY ───────────────────────────────────────────────────
function openInquiry(id,type){
  document.getElementById('inqForm').style.display='';
  document.getElementById('inqSuccess').style.display='none';
  document.getElementById('inqType').value=(type==='purchase'||type==='similar')?'purchase':type==='commission'?'commission':type==='mural'?'mural':'general';
  const f=document.getElementById('inqFor');
  if(id){const a=artworks.find(x=>x.id===id);f.style.display='';f.innerHTML=`Regarding: <strong>${a.title}</strong> · ${a.medium}, ${a.size}${a.sold?' <span style="color:#e55;">· Sold</span>':''}`;}
  else f.style.display='none';
  document.getElementById('inquiryModal').classList.add('open'); document.body.style.overflow='hidden';
  document.getElementById('lightbox').classList.remove('open');
}
function closeInquiry(e){
  if(e&&e.target!==document.getElementById('inquiryModal'))return;
  document.getElementById('inquiryModal').classList.remove('open'); document.body.style.overflow='';
}

// ── EVENT LISTENERS ───────────────────────────────────────────
document.getElementById('prevBtn').onclick=()=>changeSlide(-1);
document.getElementById('nextBtn').onclick=()=>changeSlide(1);
document.getElementById('fullViewBtn').onclick=openLightboxFromSlide;
document.getElementById('lbCloseBtn').onclick=()=>closeLightbox({target:document.getElementById('lightbox')});
document.getElementById('lbPrevBtn').onclick=()=>lbNav(-1);
document.getElementById('lbNextBtn').onclick=()=>lbNav(1);
document.getElementById('lightbox').onclick=closeLightbox;
document.getElementById('lbInner').onclick=e=>e.stopPropagation();
document.getElementById('inqCloseBtn').onclick=()=>closeInquiry({target:document.getElementById('inquiryModal')});
document.getElementById('inquiryModal').onclick=closeInquiry;
document.getElementById('inqBox').onclick=e=>e.stopPropagation();
document.getElementById('inqSubmitBtn').onclick=()=>{
  if(!document.getElementById('inqFirst').value.trim()||!document.getElementById('inqEmail').value.trim()){alert('Please fill in your name and email.');return;}
  document.getElementById('inqForm').style.display='none'; document.getElementById('inqSuccess').style.display='block';
  setTimeout(()=>{document.getElementById('inquiryModal').classList.remove('open');document.body.style.overflow='';},3500);
};
document.getElementById('submitPhotoBtn').onclick=()=>openInquiry(null,'general');
document.getElementById('muralInquiryBtn').onclick=()=>openInquiry(null,'mural');
document.getElementById('shopChaseBtn').onclick=()=>{
  const btn=document.querySelector('.filter-btn[data-cat="chase"]');
  filterGallery('chase',btn);
  document.getElementById('cinematicViewer').scrollIntoView({behavior:'smooth'});
};
document.querySelectorAll('.filter-btn').forEach(btn=>{
  btn.onclick=()=>filterGallery(btn.dataset.cat,btn);
});

document.addEventListener('keydown',e=>{
  if(document.getElementById('lightbox').classList.contains('open')){
    if(e.key==='ArrowLeft')lbNav(-1); if(e.key==='ArrowRight')lbNav(1);
    if(e.key==='Escape')closeLightbox({target:document.getElementById('lightbox')}); return;
  }
  if(e.key==='ArrowUp'||e.key==='ArrowLeft')changeSlide(-1);
  if(e.key==='ArrowDown'||e.key==='ArrowRight')changeSlide(1);
  if(e.key==='Escape'){document.getElementById('inquiryModal').classList.remove('open');document.body.style.overflow='';}
});

const ro=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');}),{threshold:0.15});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

let tx=0,ty=0;
document.getElementById('cinematicViewer').addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
document.getElementById('cinematicViewer').addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)>Math.abs(dy)&&Math.abs(dx)>40)changeSlide(dx<0?1:-1);
},{passive:true});
document.getElementById('cinematicViewer').addEventListener('click',()=>{clearInterval(autoPlay);clearInterval(progressTimer);});

// ── INIT ──────────────────────────────────────────────────────
buildCinema(artworks); buildThumbs(artworks); buildGrid(artworks);
buildChaseGrid(); buildTicker(); buildProjects(); startAutoPlay();
</script>

<style>
  /* HERO */
  .hero{padding:9rem 3rem 5rem;text-align:center;background:linear-gradient(135deg,#080808,#0f0800,#080808);position:relative;overflow:hidden;}
  .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(201,168,76,0.07),transparent 65%);}
  .hero-tag{display:inline-flex;align-items:center;gap:0.8rem;margin-bottom:1.5rem;animation:fadeUp 0.8s 0.2s both;}
  .hero-line{width:30px;height:1px;background:var(--gold);}
