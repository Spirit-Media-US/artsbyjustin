---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const [siteSettings, allArtworks] = await Promise.all([
  sanityClient.fetch(`*[_type == "siteSettings"][0]`),
  sanityClient.fetch(`
    *[_type == "artwork"] | order(order asc, _createdAt desc) {
      _id,
      title,
      image,
      medium,
      year,
      available,
      category
    }
  `)
]);

const settings = siteSettings || {};
const { artistName = 'Justin' } = settings;
const categories = ['All', ...Array.from(new Set(allArtworks.map((w: any) => w.category).filter(Boolean)))];
---
<Layout title="Portfolio" description="View the complete portfolio of works by Justin">
  <Nav slot="nav" />
  
  <section class="portfolio-hero reveal">
    <h1>Portfolio</h1>
    <p>A curated selection of paintings, drawings, and mixed media works from the studio.</p>
  </section>

  <section class="portfolio-grid-section">
    <div class="portfolio-inner">
      {categories.length > 1 && (
        <div class="category-filters reveal">
          {categories.map((cat: string) => (
            <button 
              class="filter-btn" 
              data-filter={cat.toLowerCase()}
              data-is-all={cat === 'All' ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </div>
      )}

      {allArtworks && allArtworks.length > 0 ? (
        <div class="works-grid">
          {allArtworks.map((work: any, i: number) => (
            <article 
              class="work-card reveal" 
              data-category={work.category || 'all'}
              style={`animation-delay:${(i%4)*0.07}s`}
            >
              <div class="work-image">
                {work.image && work.image.asset
                  ? <img 
                      src={urlFor(work.image).width(400).height(500).fit('crop').url()} 
                      alt={work.title}
                      loading="lazy"
                    />
                  : <div class="img-placeholder"><span>{work.title}</span></div>
                }
              </div>
              <div class="work-meta">
                <h3>{work.title}</h3>
                <p class="meta-info">
                  {[work.medium, work.year].filter(Boolean).join(' · ')}
                </p>
                <span class={`badge ${work.available ? 'available' : 'sold'}`}>
                  {work.available ? 'Available' : 'Sold'}
                </span>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="no-works reveal" style="text-align:center; padding:4rem 2rem; color:#8B7355;">
          <p>Gallery coming soon. Check back for updates.</p>
        </div>
      )}
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-inner reveal">
      <h2>Commission a Custom Work</h2>
      <p>Interested in a custom piece? Justin accepts a limited number of projects each season.</p>
      <a href="/commissions" class="btn-primary">Start an Inquiry</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const workCards = document.querySelectorAll('.work-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active state
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter works
        const isAll = btn.dataset.isAll === 'true';
        const filter = btn.dataset.filter;

        workCards.forEach(card => {
          if (isAll) {
            card.style.display = 'block';
            card.style.animation = 'none';
            setTimeout(() => card.style.animation = '', 10);
          } else {
            const cardCat = card.dataset.category;
            if (cardCat === filter) {
              card.style.display = 'block';
              card.style.animation = 'none';
              setTimeout(() => card.style.animation = '', 10);
            } else {
              card.style.display = 'none';
            }
          }
        });
      });
    });

    // Set first button as active
    if (filterBtns.length > 0) {
      filterBtns[0].classList.add('active');
    }
  });
</script>

<style>
  .portfolio-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 5rem; text-align:center; }
  .portfolio-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .portfolio-hero p { color:#8B7355; max-width:600px; margin:0 auto; font-size:1.0625rem; line-height:1.75; }
  .portfolio-grid-section { background:#F7F4EE; padding:5rem 2.5rem 6rem; }
  .portfolio-inner { max-width:1280px; margin:0 auto; }
  .category-filters { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-bottom:4rem; }
  .filter-btn { background:transparent; border:1px solid #3D3D3A; color:#3D3D3A; padding:0.5rem 1rem; font-size:0.85rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; cursor:pointer; transition:all 0.25s; }
  .filter-btn:hover { background:#3D3D3A; color:#EDE8DF; }
  .filter-btn.active { background:#C4622D; color:#F7F4EE; border-color:#C4622D; }
  .works-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; }
  .work-card { cursor:pointer; }
  .work-image { background:#EDE8DF; height:400px; overflow:hidden; border:1px solid rgba(139,115,85,0.15); }
  .work-image img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; }
  .work-card:hover .work-image img { transform:scale(1.03); }
  .work-meta { padding:1rem 0; }
  .work-meta h3 { font-family:'Playfair Display',serif; font-size:0.95rem; font-weight:600; margin-bottom:0.25rem; }
  .meta-info { font-size:0.75rem; color:#8B7355; margin-bottom:0.5rem; }
  .badge { font-size:0.65rem; letter-spacing:0.08em; text-transform:uppercase; padding:0.3rem 0.75rem; display:inline-block; }
  .badge.available { background:rgba(196,98,45,0.1); color:#C4622D; }
  .badge.sold { background:rgba(26,26,24,0.07); color:#8B7355; }
  .img-placeholder { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px dashed #8B7355; color:#8B7355; font-size:0.8rem; text-align:center; padding:2rem; width:100%; height:400px; font-family:'Playfair Display',serif; box-sizing:border-box; }
  .img-placeholder span { font-size:1rem; color:#3D3D3A; font-weight:600; }
  .no-works { color:#8B7355; }
  .cta-section { background:#1A1A18; color:#EDE8DF; padding:6rem 2.5rem; text-align:center; }
  .cta-inner { max-width:760px; margin:0 auto; }
  .cta-section h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .cta-section p { color:#8B7355; font-size:1.0625rem; line-height:1.75; margin-bottom:2rem; }
  .btn-primary { display:inline-block; background:#C4622D; color:#F7F4EE; padding:0.875rem 2rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s; }
  .btn-primary:hover { background:#A8501F; }
  @media (max-width:1024px) { 
    .works-grid { grid-template-columns:repeat(3,1fr); gap:1.5rem; }
    .portfolio-grid-section { padding:4rem 2.5rem 5rem; }
  }
  @media (max-width:768px) { 
    .works-grid { grid-template-columns:repeat(2,1fr); gap:1.5rem; }
    .category-filters { justify-content:flex-start; }
  }
  @media (max-width:640px) { 
    .portfolio-hero,.portfolio-grid-section,.cta-section { padding-inline:1.5rem; } 
    .works-grid { grid-template-columns:1fr; }
    .category-filters { gap:0.5rem; }
    .filter-btn { padding:0.4rem 0.75rem; font-size:0.75rem; }
  }
</style>
