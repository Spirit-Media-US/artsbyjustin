---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const series = ['All','Oil & Acrylic','Watercolor','Mixed Media','Charcoal & Ink','Prints'];
const slugs =  ['all','oil','watercolor','mixed','charcoal','prints'];
const works = [
  { title:'Untitled Study No. 1', medium:'Oil on canvas', year:'2024', category:'oil', size:'24×30 in', available:true },
  { title:'Layered Light', medium:'Mixed media on board', year:'2024', category:'mixed', size:'18×24 in', available:true },
  { title:'Between', medium:'Watercolor & ink', year:'2023', category:'watercolor', size:'11×15 in', available:false },
  { title:'Still Ground', medium:'Acrylic & collage', year:'2024', category:'mixed', size:'30×36 in', available:true },
  { title:'Remnant', medium:'Charcoal & oil', year:'2023', category:'charcoal', size:'16×20 in', available:false },
  { title:'Field Notes I', medium:'Watercolor on paper', year:'2024', category:'watercolor', size:'9×12 in', available:true },
  { title:'Weight', medium:'Oil on canvas', year:'2023', category:'oil', size:'36×48 in', available:false },
  { title:'Open Study', medium:'Mixed media', year:'2024', category:'mixed', size:'20×20 in', available:true },
  { title:'Impression No. 3', medium:'Charcoal on paper', year:'2023', category:'charcoal', size:'18×24 in', available:true },
  { title:'Archive', medium:'Collage & acrylic', year:'2024', category:'mixed', size:'24×24 in', available:true },
  { title:'Soft Boundary', medium:'Watercolor', year:'2024', category:'watercolor', size:'12×16 in', available:true },
  { title:'Edition I', medium:'Giclee print', year:'2024', category:'prints', size:'18×24 in', available:true },
];
---
<Layout title="Portfolio" description="Browse Justin's portfolio of original paintings, mixed media works, and prints.">
  <Nav slot="nav" />
  <section class="portfolio-hero reveal">
    <p class="eyebrow">Portfolio</p>
    <h1>Original Works</h1>
    <p class="sub">A selection of paintings, drawings, and mixed media pieces — each one a distinct encounter.</p>
  </section>
  <div class="filter-bar">
    {series.map((s,i) => (
      <button class="filter-btn" data-filter={slugs[i]} class:list={[{active:slugs[i]==='all'}]}>{s}</button>
    ))}
  </div>
  <section class="gallery-grid" id="gallery">
    {works.map((work,i) => (
      <article class="gallery-item reveal" data-category={work.category} style={`animation-delay:${(i%4)*0.07}s`}>
        <div class="gallery-img-placeholder"><span>{work.title}</span></div>
        <div class="gallery-meta">
          <div><h3>{work.title}</h3><p>{work.medium} · {work.year} · {work.size}</p></div>
          {work.available ? <span class="badge available">Available</span> : <span class="badge sold">Sold</span>}
        </div>
      </article>
    ))}
  </section>
  <Footer slot="footer" />
</Layout>
<style>
  .portfolio-hero { max-width:1280px; margin:0 auto; padding:10rem 2.5rem 3rem; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1rem; }
  .portfolio-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(2.5rem,5vw,4.5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1rem; }
  .sub { color:#3D3D3A; max-width:500px; font-size:1.0625rem; line-height:1.7; }
  .filter-bar { max-width:1280px; margin:0 auto 3rem; padding:0 2.5rem 1.5rem; display:flex; gap:0.5rem; flex-wrap:wrap; border-bottom:1px solid rgba(26,26,24,0.1); }
  .filter-btn { background:none; border:1px solid rgba(26,26,24,0.15); padding:0.5rem 1.25rem; font-size:0.8rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; cursor:pointer; color:#3D3D3A; transition:all 0.2s; }
  .filter-btn:hover,.filter-btn.active { background:#1A1A18; color:#F7F4EE; border-color:#1A1A18; }
  .gallery-grid { max-width:1280px; margin:0 auto 6rem; padding:0 2.5rem; display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; }
  .gallery-item { cursor:pointer; }
  .gallery-item.hidden { display:none; }
  .gallery-img-placeholder { background:#EDE8DF; height:320px; display:flex; align-items:flex-end; padding:1rem; border:1px solid rgba(139,115,85,0.15); transition:filter 0.3s; color:#8B7355; font-family:'Playfair Display',serif; font-size:0.875rem; font-style:italic; }
  .gallery-item:hover .gallery-img-placeholder { filter:brightness(0.95); }
  .gallery-meta { display:flex; justify-content:space-between; align-items:flex-start; padding:0.875rem 0 0; gap:1rem; }
  .gallery-meta h3 { font-family:'Playfair Display',serif; font-size:1rem; font-weight:600; margin-bottom:0.25rem; }
  .gallery-meta p { font-size:0.8rem; color:#8B7355; }
  .badge { font-size:0.7rem; letter-spacing:0.08em; text-transform:uppercase; padding:0.3rem 0.75rem; white-space:nowrap; flex-shrink:0; margin-top:0.25rem; }
  .badge.available { background:rgba(196,98,45,0.1); color:#C4622D; }
  .badge.sold { background:rgba(26,26,24,0.07); color:#8B7355; }
  @media (max-width:1024px) { .gallery-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px) { .portfolio-hero,.filter-bar,.gallery-grid { padding-inline:1.5rem; } .gallery-grid { grid-template-columns:1fr; } }
</style>
<script>
  const btns = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.gallery-item');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      items.forEach(item => {
        item.classList.toggle('hidden', filter !== 'all' && item.getAttribute('data-category') !== filter);
      });
    });
  });
</script>
