  .filter-btn:hover,.filter-btn.active{background:var(--gold);color:var(--black);border-color:var(--gold);font-weight:600;}

  /* CINEMATIC */
  .cinematic{position:relative;height:90vh;overflow:hidden;background:var(--black);}
