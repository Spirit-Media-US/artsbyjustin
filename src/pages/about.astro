---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { sanityClient, urlFor } from '../lib/sanity.ts';

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const settings = siteSettings || {};
const { artistName = 'Justin', bio = '', heroImage } = settings;
---
<Layout title="About" description="Learn about Justin's artistic practice and approach.">
  <Nav slot="nav" />
  <section class="about-hero reveal">
    <div class="hero-inner">
      <p class="eyebrow">About</p>
      <h1>Creative Journey</h1>
      <p class="sub">A painter and maker based in {artistName}'s studio, exploring color, form, and the intersection of traditional and contemporary practice.</p>
    </div>
  </section>

  <section class="about-body">
    <div class="about-grid">
      <div class="about-content reveal">
        {bio && (
          <div class="bio-section">
            <h2>Practice</h2>
            <div class="bio-text" set:html={bio.replace(/\n\n/g, '</p><p>')} />
          </div>
        )}
        <div class="highlights">
          <h3>Approach</h3>
          <ul class="highlight-list">
            <li><strong>Materiality:</strong> Careful attention to surface, texture, and color relationships</li>
            <li><strong>Process:</strong> Iterative exploration combining traditional drawing with contemporary techniques</li>
            <li><strong>Scale:</strong> Work ranges from intimate studies to large installations</li>
            <li><strong>Collaboration:</strong> Open to commissioned work and site-specific projects</li>
          </ul>
        </div>
      </div>
      <div class="about-image reveal">
        {heroImage && heroImage.asset 
          ? <img 
              src={urlFor(heroImage).width(500).height(600).url()} 
              alt={artistName}
              loading="lazy"
            />
          : <div class="img-placeholder">
              <span>Portrait</span>
              <p>Artist portrait from Sanity</p>
            </div>
        }
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="timeline-inner">
      <h2 class="reveal">Milestones</h2>
      <div class="timeline">
        <div class="timeline-item reveal">
          <div class="timeline-date">Present</div>
          <div class="timeline-content">
            <h4>Studio Practice</h4>
            <p>Full-time focus on commissions, exhibitions, and self-directed work.</p>
          </div>
        </div>
        <div class="timeline-item reveal">
          <div class="timeline-date">2022</div>
          <div class="timeline-content">
            <h4>Launch</h4>
            <p>Opened studio to commissions and began scaling production.</p>
          </div>
        </div>
        <div class="timeline-item reveal">
          <div class="timeline-date">2020</div>
          <div class="timeline-content">
            <h4>Practice Foundation</h4>
            <p>Developed core artistic voice and techniques through dedicated studio time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .about-hero { background:#1A1A18; color:#EDE8DF; padding:10rem 2.5rem 5rem; }
  .hero-inner { max-width:1280px; margin:0 auto; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1rem; }
  .about-hero h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,6vw,5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1rem; }
  .sub { color:#8B7355; max-width:520px; line-height:1.75; font-size:1.0625rem; }
  .about-body { max-width:1280px; margin:0 auto; padding:5rem 2.5rem 6rem; }
  .about-grid { display:grid; grid-template-columns:2fr 1fr; gap:5rem; align-items:start; }
  .bio-section h2 { font-family:'Playfair Display',serif; font-size:1.75rem; font-weight:600; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .bio-text { color:#3D3D3A; font-size:1.0625rem; line-height:1.8; }
  .bio-text p { margin-bottom:1.5rem; }
  .highlights { margin-top:3rem; padding-top:3rem; border-top:1px solid rgba(26,26,24,0.1); }
  .highlights h3 { font-family:'Playfair Display',serif; font-size:1.125rem; font-weight:600; margin-bottom:1rem; }
  .highlight-list { list-style:none; display:flex; flex-direction:column; gap:1rem; }
  .highlight-list li { color:#3D3D3A; font-size:0.95rem; line-height:1.7; }
  .highlight-list strong { color:#C4622D; }
  .about-image { position:relative; }
  .about-image img { width:100%; height:auto; display:block; border:1px solid rgba(139,115,85,0.15); }
  .img-placeholder { background:#EDE8DF; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px dashed #8B7355; color:#8B7355; font-size:0.8rem; text-align:center; padding:2rem; min-height:400px; font-family:'Playfair Display',serif; }
  .img-placeholder span { font-size:1rem; color:#3D3D3A; font-weight:600; }
  .timeline-section { background:#F7F4EE; padding:6rem 2.5rem; }
  .timeline-inner { max-width:800px; margin:0 auto; }
  .timeline-section h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; text-align:center; margin-bottom:4rem; }
  .timeline { display:flex; flex-direction:column; gap:2rem; }
  .timeline-item { display:grid; grid-template-columns:140px 1fr; gap:2rem; padding:1.5rem 0; border-bottom:1px solid rgba(26,26,24,0.08); }
  .timeline-item:last-child { border-bottom:none; }
  .timeline-date { font-family:'Playfair Display',serif; font-size:1.25rem; font-weight:600; color:#C4622D; }
  .timeline-content h4 { font-family:'Playfair Display',serif; font-size:1rem; font-weight:600; margin-bottom:0.5rem; color:#1A1A18; }
  .timeline-content p { color:#3D3D3A; font-size:0.95rem; line-height:1.65; }
  @media (max-width:1024px) { 
    .about-grid { grid-template-columns:1fr; gap:3rem; }
    .timeline-item { grid-template-columns:100px 1fr; }
  }
  @media (max-width:640px) { 
    .about-hero,.about-body,.timeline-section { padding-inline:1.5rem; } 
    .timeline-item { grid-template-columns:60px 1fr; gap:1rem; }
    .timeline-date { font-size:0.9rem; }
  }
</style>
