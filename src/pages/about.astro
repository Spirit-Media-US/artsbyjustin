---
import Layout from '../layouts/Layout.astro';
import { sanityClient, urlFor } from '../lib/sanity';

let siteSettings: any = {};
try { siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`) || {}; } catch (e) {}

const portraitUrl = siteSettings?.profilePhoto
  ? urlFor(siteSettings.profilePhoto).width(800).url()
  : null;
const instagramUrl = siteSettings?.instagramUrl || null;
const facebookUrl  = siteSettings?.facebookUrl  || null;
const tiktokUrl    = siteSettings?.tiktokUrl    || null;
---
<Layout title="The Story" description="From a village in Ukhrul, Manipur, India to international recognition — the story of Justin Keishing, Arts by Justin.">

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-eyebrow">
      <div class="hero-line"></div>
      <span>The Story of Justin Keishing</span>
    </div>
    <h1>From a Village<br/>in India<br/><em>to the World.</em></h1>
    <p class="hero-opening">
      A boy born in Ukhrul, Manipur — with no money, no formal art training, and a dream that everyone told him was impossible. Today he is an internationally recognized fine artist, based in Raleigh, NC, with collectors across the globe.
    </p>
    <div class="hero-origin">
      <span class="origin-flag">🇮🇳 → 🇺🇸</span>
      <div class="origin-text">
        <strong>Ukhrul, Manipur, India → Raleigh, North Carolina</strong>
        Living proof that dreams really do come true.
      </div>
    </div>
    <div class="scroll-hint">
      <div class="scroll-line"></div>
      <span>Read the story</span>
    </div>
  </div>
  <div class="hero-right">
    {portraitUrl
      ? <img src={portraitUrl} alt="Justin Keishing" class="portrait-img" loading="eager"/>
      : <div class="portrait-placeholder">
          <div class="portrait-placeholder-inner">
            <div style="font-size:4rem; opacity:0.2;">📷</div>
            <div style="font-size:0.65rem; letter-spacing:3px; text-transform:uppercase; margin-top:1rem; opacity:0.2;">Portrait Photo</div>
          </div>
        </div>
    }
  </div>
</section>

<!-- CHAPTER 1 -->
<section class="chapter ch-dark">
  <div class="chapter-visual" style="background:linear-gradient(135deg,#0a1008,#050805);">
    <div class="chapter-num">01</div>
    <div class="chapter-visual-inner">
      <div class="chapter-img-box chapter-img-box--placeholder">
        <div style="font-size:3rem; opacity:0.15;">🏔️</div>
        <div style="font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; margin-top:1rem; color:var(--gold); opacity:0.5;">Ukhrul, Manipur · India</div>
      </div>
    </div>
  </div>
  <div class="chapter-body" style="background:#111;">
    <p class="label">Chapter One</p>
    <div class="bar"></div>
    <h2>Born in Ukhrul,<br/>Raised on Faith</h2>
    <p>Justin Keishing was born and raised in Ukhrul District, Manipur, in Northeast India — a small, mountainous community far from the art world's centers of power. His family had very little. His father passed away when Justin was just 3 years old, leaving his mother to raise him and his five siblings alone, with no income and borrowed land.</p>
    <p>His mother — a woman of extraordinary faith and determination — refused to let circumstances define her children's futures. Despite having nothing, she made sure every one of her children received an education. She sent them all to college. Then, when Justin was 19, she too passed away from breast cancer.</p>
    <div class="pull-quote">
      <p>"Her last words to us were, 'Love one another.' She is the reason I never stopped believing."</p>
    </div>
    <p>Justin carries his mother's prayers in every brushstroke. Her sacrifice is the foundation everything else is built on.</p>
  </div>
</section>

<!-- CHAPTER 2 -->
<section class="chapter flip ch-darker">
  <div class="chapter-visual" style="background:linear-gradient(135deg,#0a0808,#080505);">
    <div class="chapter-num" style="right:2rem; left:auto;">02</div>
    <div class="chapter-visual-inner">
      <div class="chapter-img-box chapter-img-box--placeholder" style="background:linear-gradient(135deg,#1a0a00,#110800); border-color:rgba(201,168,76,0.08);">
        <div style="font-size:3rem; opacity:0.15;">✈️</div>
        <div style="font-size:0.6rem; letter-spacing:2px; text-transform:uppercase; margin-top:1rem; color:var(--gold); opacity:0.5;">The Journey to America</div>
      </div>
    </div>
  </div>
  <div class="chapter-body" style="background:#0d0d0d;">
    <p class="label">Chapter Two</p>
    <div class="bar"></div>
    <h2>The Dream They Said<br/>Would Never Happen</h2>
    <p>As a boy, Justin told his teacher he wanted to travel the world. That dream was met with doubt — not cruelty, just the quiet disbelief that surrounds children who dare to dream too big for their circumstances.</p>
    <p>He tried four times to get a US visa. On his fourth attempt, the woman at the US Embassy didn't just deny his application — she looked him in the eye and said, <em style="color:var(--gold-light);">"Sir, you will never see the USA in your lifetime."</em></p>
    <p>He flew back home. He applied a fifth time. On the fifth application, God granted him a 10-year US visa.</p>
    <div class="pull-quote">
      <p>"I was devastated. But a friend encouraged me that God always has the final word. So I applied again. And I got it. It was a miracle."</p>
    </div>
    <p>In January 2020, Justin entered the USA. His return flight to India was cancelled due to COVID. He was stranded — and that's when everything changed.</p>
  </div>
</section>

<!-- FULL WIDTH QUOTE -->
<div class="full-quote">
  <blockquote>
    "I started watching Bob Ross videos. Then I picked up a brush. I had no formal training — <em>just a dream and a canvas.</em> When the public began paying for my art, I was shocked. I'm so thankful."
  </blockquote>
  <cite>— Justin Keishing · Arts by Justin</cite>
</div>

<!-- CHAPTER 3 -->
<section class="chapter ch-dark">
  <div class="chapter-visual" style="background:linear-gradient(135deg,#080808,#0a0a14);">
    <div class="chapter-num">03</div>
    <div class="chapter-visual-inner">
      <div class="chapter-img-box" style="background:linear-gradient(135deg,#000,#111,#ff6600,#00aacc); display:flex; align-items:center; justify-content:center;">
        <div style="font-size:0.65rem; letter-spacing:3px; text-transform:uppercase; color:rgba(255,255,255,0.4); text-align:center; padding:1rem;">The Creator's Hand · Mixed Media</div>
      </div>
    </div>
  </div>
  <div class="chapter-body" style="background:#111;">
    <p class="label">Chapter Three</p>
    <div class="bar"></div>
    <h2>A Pandemic,<br/>a Brush, a Calling</h2>
    <p>Stranded in America during COVID-19, Justin turned to YouTube. He began watching Bob Ross. He experimented. He practiced. He had no art school, no mentor, no connections — just a burning sense that he was supposed to create.</p>
    <p>In June 2021, he entered his first art show. He was nervous. He was unsure. And then — people loved his work. They didn't just admire it. They bought it.</p>
    <p>His Etsy store exploded. He became a Star Seller. His work began reaching collectors in New York, Las Vegas, California, Florida, Alaska, Hawaii, the UK, France, Canada, and India.</p>
    <div class="pull-quote">
      <p>"Every piece of art starts with a dream. Every display of my art continues with gratitude."</p>
    </div>
    <p>Within a year, what started as a stranded traveler watching YouTube videos had become a thriving international art business.</p>
  </div>
</section>

<!-- CHAPTER 4 -->
<section class="chapter flip ch-gold">
  <div class="chapter-visual" style="background:linear-gradient(135deg,#0d0800,#130900);">
    <div class="chapter-num" style="right:2rem; left:auto; color:rgba(201,168,76,0.06);">04</div>
    <div class="chapter-visual-inner">
      <div class="chapter-img-box" style="background:linear-gradient(135deg,#1a1000,#0d0800); border:1px solid rgba(201,168,76,0.2); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1rem; padding:2rem;">
        <div style="font-size:3rem;">🏆</div>
        <div style="text-align:center;">
          <div style="font-family:'Playfair Display',serif; font-size:0.9rem; color:var(--gold-light); font-style:italic;">International Prize</div>
          <div style="font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--white);">Artist of the Year 2025</div>
          <div style="font-size:0.65rem; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-top:0.5rem;">Palazzo Pitti · Florence, Italy</div>
        </div>
      </div>
    </div>
  </div>
  <div class="chapter-body" style="background:linear-gradient(135deg,#0d0800,#130900);">
    <p class="label">Chapter Four</p>
    <div class="bar"></div>
    <h2>From Raleigh<br/>to Florence, Italy</h2>
    <p>In just a few years, Justin went from watching Bob Ross alone during a pandemic to standing in the historic Palazzo Pitti in Florence, Italy — receiving the International Prize for Artist of the Year 2025.</p>
    <p>He was recognized by Cary Magazine as a 2022 Mover & Shaker. A U.S. Congresswoman wrote him a personal letter. He was featured in newspapers in India, digital publications in Raleigh, and international art catalogs.</p>
    <p>His "Empress" painting was published across two full pages in the international "Master Artists to Collect" publication alongside the Florence award ceremony.</p>
    <div class="pull-quote">
      <p>"The boy from Ukhrul who was told he'd never see America — is now recognized in Italy. God always has the final word."</p>
    </div>
  </div>
</section>

<!-- FAITH -->
<section class="faith">
  <div class="faith-icon-col">
    <span class="faith-cross">✝️</span>
    <div class="faith-verse">"Fear not, for I am with you."</div>
    <div class="faith-verse-ref">Isaiah 41:10 — tattooed on Justin's arm</div>
  </div>
  <div class="faith-body">
    <p class="label">Faith & Art</p>
    <div class="bar"></div>
    <h2>Art as an Act<br/>of Faith</h2>
    <p>Justin's faith is not separate from his art. It is the art. Every canvas begins with prayer. Every brushstroke is an act of trust that what he creates matters — that it will reach the person who needs to see it.</p>
    <p>He has the words <em style="color:var(--gold-light);">"Fear not, for I am with you"</em> tattooed on his arm — a daily reminder that fear is real, but faith is stronger. It is the same message woven into his most powerful works: the reaching hand, the exploding heart, the figure soaring above the world.</p>
    <div class="tattoo-quote">
      <p>"My faith has guided me to overcome a lifetime of fear."</p>
      <span>— Justin Keishing</span>
    </div>
    <p>A portion of every sale goes toward sponsoring education for needy children and deaf children in India. Because for Justin, art with a purpose means giving back to the village that shaped him.</p>
  </div>
</section>

<!-- JOURNEY STATS -->
<div class="journey-stats">
  <div class="j-stat"><div class="j-num">8,000+</div><div class="j-label">Miles from Home</div></div>
  <div class="j-stat"><div class="j-num">5</div><div class="j-label">Visa Applications to Get Here</div></div>
  <div class="j-stat"><div class="j-num">0</div><div class="j-label">Formal Art Training</div></div>
  <div class="j-stat"><div class="j-num">∞</div><div class="j-label">Reasons to Keep Going</div></div>
</div>

<!-- PURPOSE -->
<section class="purpose">
  <div style="text-align:center;">
    <p class="label" style="text-align:center;">Why He Creates</p>
    <div class="bar" style="margin:0.5rem auto 1rem;"></div>
    <h2 style="font-family:'Playfair Display',serif; font-size:2.2rem; margin-bottom:0.8rem;">Art With a Purpose</h2>
    <p style="color:var(--gray2); max-width:580px; margin:0 auto; font-size:0.93rem; font-weight:300; line-height:1.9;">Justin doesn't create for fame or money. He creates because he believes art has the power to change lives — starting with the person standing in front of the canvas.</p>
  </div>
  <div class="purpose-grid">
    <div class="purpose-card">
      <span class="purpose-icon">🎨</span>
      <h3>To Inspire</h3>
      <p>Every painting is a message — that beauty is possible, that color exists even in darkness, that your story is worth telling. Justin creates to move people out of numbness and into feeling.</p>
    </div>
    <div class="purpose-card">
      <span class="purpose-icon">🌱</span>
      <h3>To Give Back</h3>
      <p>A portion of every sale funds education for needy and deaf children in India. The boy who was helped by his mother's faith is now helping the next generation chase their dreams.</p>
    </div>
    <div class="purpose-card">
      <span class="purpose-icon">💫</span>
      <h3>To Prove It's Possible</h3>
      <p>Justin's story is the message. A poor orphan boy from a tiny village in Northeast India — with no training, no connections, and no guarantee — became an internationally recognized artist. If he can, you can.</p>
    </div>
  </div>
</section>

<!-- FOR THE DREAMERS -->
<section class="dreamers">
  <div class="dreamers-text">
    <p class="label">For Every Dreamer</p>
    <div class="bar"></div>
    <h2>This Is for the Kids<br/>Who Were Told<br/><em>"It's Impossible."</em></h2>
    <p>Justin knows what it feels like to have a dream that feels too big for your circumstances. He knows what it's like to be poor, to lose your parents, to be told no — over and over — by the very systems that were supposed to help you.</p>
    <p>And he knows what it feels like to make it anyway.</p>
    <div class="dreamers-list">
      <div class="dream-item"><div class="dream-dot"></div><p>If you grew up in poverty and stopped dreaming — Justin's story is for you.</p></div>
      <div class="dream-item"><div class="dream-dot"></div><p>If someone told you your dream would never come true — Justin's story is for you.</p></div>
      <div class="dream-item"><div class="dream-dot"></div><p>If you're young and you feel like the world wasn't built for you — Justin's story is for you.</p></div>
    </div>
    <p style="color:var(--white); font-size:0.95rem; line-height:1.9;">"I encourage everyone to have dreams and to chase them. Even as a poor orphan boy from a tiny village in Northeast India — I'm living proof that dreams really do come true."</p>
  </div>
  <div class="dreamers-visual">
    <div class="dreamers-card">
      <p class="dream-verse">"Every piece of art starts with a dream. Every display of my art continues <em>with gratitude.</em>"</p>
      <div class="dream-from">— Justin Keishing · Arts by Justin</div>
      <div class="dream-justin">
        <strong>Chase Your Dreams</strong> — Justin's most beloved series — was born from this belief. It features athletes, musicians, emergency services personnel, and everyday people demonstrating their gifts with a burst of color following them.<br/><br/>
        The series isn't just art. It's a movement.
      </div>
    </div>
  </div>
</section>

<!-- SOCIAL -->
<section class="social-strip">
  <p class="label" style="text-align:center;">Follow the Journey</p>
  <div class="bar" style="margin:0.5rem auto 1.5rem;"></div>
  <h2>Watch the Story Unfold</h2>
  <p>Follow Justin behind the scenes — new works, art shows, studio visits, and the ongoing journey.</p>
  <div class="social-handles">
    {instagramUrl
      ? <a href={instagramUrl} target="_blank" rel="noopener" class="handle">📸 Instagram</a>
      : <a href="https://www.instagram.com/artsbyjustin" target="_blank" rel="noopener" class="handle">📸 Instagram</a>
    }
    {facebookUrl
      ? <a href={facebookUrl} target="_blank" rel="noopener" class="handle">👤 Facebook</a>
      : <a href="https://www.facebook.com/artsbyjustin" target="_blank" rel="noopener" class="handle">👤 Facebook</a>
    }
    {tiktokUrl && <a href={tiktokUrl} target="_blank" rel="noopener" class="handle">🎵 TikTok</a>}
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <h2>Moved by the story?<br/><em>Explore the work.</em></h2>
  <p>Every painting Justin creates carries this story inside it. Browse the portfolio, commission an original piece, or reach out to connect personally.</p>
  <a href="/" class="btn-gold">View the Portfolio →</a>
  <a href="/commissions" class="btn-ghost">Start a Commission →</a>
</section>

</Layout>

<style>
/* HERO */
.hero { min-height:100vh; display:grid; grid-template-columns:1fr 1fr; position:relative; overflow:hidden; }
.hero-left { padding:10rem 4rem 5rem; display:flex; flex-direction:column; justify-content:center; position:relative; z-index:2; }
.hero-left::after { content:''; position:absolute; right:0; top:0; bottom:0; width:1px; background:linear-gradient(to bottom,transparent,rgba(201,168,76,0.3),transparent); }
.hero-right { position:relative; overflow:hidden; background:linear-gradient(135deg,#101510,#0a1008,#050805); }
.hero-right::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 40% 50%,rgba(201,168,76,0.12),transparent 65%); z-index:1; pointer-events:none; }
.hero-right::after { content:''; position:absolute; left:0; top:0; bottom:0; width:40%; background:linear-gradient(to right,var(--black),transparent); z-index:2; pointer-events:none; }
.portrait-img { width:100%; height:100%; object-fit:cover; object-position:center top; display:block; }
.portrait-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; }
.portrait-placeholder-inner { text-align:center; }
.hero-eyebrow { display:inline-flex; align-items:center; gap:0.8rem; margin-bottom:2rem; }
.hero-line { width:30px; height:1px; background:var(--gold); flex-shrink:0; }
.hero-eyebrow span { font-size:0.68rem; letter-spacing:4px; text-transform:uppercase; color:var(--gold); }
.hero h1 { font-family:'Playfair Display',serif; font-size:clamp(2.8rem,4.5vw,4.5rem); line-height:1.08; margin-bottom:2rem; font-weight:700; }
.hero h1 em { color:var(--gold); font-style:italic; display:block; }
.hero-opening { font-size:1.05rem; line-height:1.95; color:var(--gray2); font-weight:300; max-width:480px; margin-bottom:2.5rem; border-left:2px solid var(--gold); padding-left:1.5rem; }
.hero-origin { display:flex; align-items:center; gap:1rem; margin-top:1rem; }
.origin-flag { font-size:1.5rem; }
.origin-text { font-size:0.78rem; color:var(--gray2); line-height:1.6; }
.origin-text strong { color:var(--white); display:block; font-size:0.82rem; letter-spacing:0.5px; }
.scroll-hint { display:flex; align-items:center; gap:1rem; color:var(--gray); font-size:0.68rem; letter-spacing:3px; text-transform:uppercase; margin-top:3rem; }
.scroll-line { width:40px; height:1px; background:var(--gold); animation:grow 2s ease-in-out infinite; }
@keyframes grow { 0%,100%{width:40px;opacity:0.4;} 50%{width:65px;opacity:1;} }

/* CHAPTERS */
.chapter { display:grid; grid-template-columns:1fr 1fr; min-height:580px; }
.chapter.flip { direction:rtl; }
.chapter.flip > * { direction:ltr; }
.chapter-visual { position:relative; overflow:hidden; }
.chapter-visual-inner { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; }
.chapter-num { position:absolute; top:2rem; left:2rem; font-family:'Playfair Display',serif; font-size:5rem; color:rgba(255,255,255,0.03); line-height:1; font-weight:700; z-index:0; }
.chapter-img-box { width:85%; height:75%; position:relative; z-index:1; overflow:hidden; background:linear-gradient(135deg,#111,#1a1a1a); border:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; }
.chapter-img-box img { width:100%; height:100%; object-fit:cover; }
.chapter-img-box--placeholder { padding:2rem; }
.chapter-body { padding:5rem 4rem; display:flex; flex-direction:column; justify-content:center; }
.chapter-body h2 { font-family:'Playfair Display',serif; font-size:2.2rem; line-height:1.2; margin-bottom:1.5rem; }
.chapter-body p { color:var(--gray2); font-size:0.93rem; line-height:1.95; margin-bottom:1rem; font-weight:300; }
.ch-dark { background:var(--dark); }
.ch-darker { background:#0d0d0d; }
.ch-gold { background:linear-gradient(135deg,#0d0800,#130900); }

/* FULL-WIDTH QUOTE */
.full-quote { padding:7rem 3rem; background:linear-gradient(135deg,#0a0a0a,#0f0800,#0a0a0a); text-align:center; position:relative; overflow:hidden; }
.full-quote::before { content:'❝'; position:absolute; top:-2rem; left:50%; transform:translateX(-50%); font-family:'Playfair Display',serif; font-size:15rem; color:rgba(201,168,76,0.04); line-height:1; }
.full-quote blockquote { font-family:'Playfair Display',serif; font-size:clamp(1.5rem,3vw,2.5rem); line-height:1.5; color:var(--white); max-width:850px; margin:0 auto 2rem; position:relative; z-index:1; font-style:italic; }
.full-quote blockquote em { color:var(--gold); }
.full-quote cite { font-size:0.75rem; letter-spacing:3px; text-transform:uppercase; color:var(--gray); }

/* FAITH */
.faith { padding:7rem 3rem; background:var(--black); display:grid; grid-template-columns:1fr 2fr; gap:5rem; align-items:center; }
.faith-icon-col { text-align:center; }
.faith-cross { font-size:5rem; margin-bottom:1.5rem; display:block; }
.faith-verse { font-family:'Playfair Display',serif; font-style:italic; font-size:1rem; color:var(--gold-light); line-height:1.8; text-align:center; }
.faith-verse-ref { font-size:0.72rem; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-top:0.8rem; text-align:center; }
.faith-body h2 { font-family:'Playfair Display',serif; font-size:2.2rem; margin-bottom:1.5rem; }
.faith-body p { color:var(--gray2); font-size:0.93rem; line-height:1.95; margin-bottom:1rem; font-weight:300; }
.tattoo-quote { margin:1.5rem 0; padding:1.5rem; border:1px solid rgba(201,168,76,0.2); background:rgba(201,168,76,0.03); text-align:center; }
.tattoo-quote p { font-family:'Playfair Display',serif; font-style:italic; font-size:1.1rem; color:var(--gold-light); line-height:1.7; }
.tattoo-quote span { font-size:0.72rem; letter-spacing:2px; text-transform:uppercase; color:var(--gray); display:block; margin-top:0.5rem; }

/* JOURNEY STATS */
.journey-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background-color:rgba(201,168,76,0.1); }
.j-stat { padding:3rem 2rem; text-align:center; background:linear-gradient(135deg,#0d0800,#130900); }
.j-num { font-family:'Playfair Display',serif; font-size:3rem; color:var(--gold); line-height:1; margin-bottom:0.5rem; }
.j-label { font-size:0.68rem; letter-spacing:2px; text-transform:uppercase; color:var(--gray2); }

/* PURPOSE */
.purpose { padding:7rem 3rem; background:var(--dark); }
.purpose-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:4rem; }
.purpose-card { padding:2.5rem; border:1px solid rgba(255,255,255,0.05); position:relative; overflow:hidden; transition:border-color 0.3s; }
.purpose-card:hover { border-color:rgba(201,168,76,0.3); }
.purpose-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(to right,var(--gold),transparent); }
.purpose-icon { font-size:2rem; margin-bottom:1.2rem; display:block; }
.purpose-card h3 { font-family:'Playfair Display',serif; font-size:1.2rem; margin-bottom:0.8rem; }
.purpose-card p { color:var(--gray2); font-size:0.85rem; line-height:1.8; }

/* DREAMERS */
.dreamers { padding:8rem 3rem; background:var(--black); display:grid; grid-template-columns:1fr 1fr; gap:6rem; align-items:center; }
.dreamers-text h2 { font-family:'Playfair Display',serif; font-size:2.5rem; line-height:1.15; margin-bottom:1.5rem; }
.dreamers-text h2 em { color:var(--gold); font-style:italic; }
.dreamers-text p { color:var(--gray2); font-size:0.95rem; line-height:1.95; margin-bottom:1rem; font-weight:300; }
.dreamers-list { margin:2rem 0; display:flex; flex-direction:column; gap:1rem; }
.dream-item { display:flex; align-items:flex-start; gap:1rem; }
