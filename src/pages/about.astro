---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="About" description="Learn about Justin, his practice, and the story behind the work.">
  <Nav slot="nav" />
  <section class="about-hero">
    <div class="about-hero-inner">
      <div class="about-hero-img reveal">
        <!-- REPLACE: assets.artsbyjustin.com/press/justin-portrait.jpg -->
        <div class="img-placeholder portrait"><span>Justin in the studio</span><p>assets.artsbyjustin.com/press/justin-portrait.jpg</p></div>
        <div class="accent-mark"></div>
      </div>
      <div class="about-hero-text reveal">
        <p class="eyebrow">About the Artist</p>
        <h1>Justin</h1>
        <p class="lead">Justin is a mixed media artist whose practice spans oil painting, watercolor, charcoal, and collage. His work explores the tension between the planned and the accidental — what happens in the space between intention and discovery.</p>
        <p>He works from his studio, building each piece through layers of material and revision. There's always a moment, he says, when a painting stops being something he's making and starts being something he's listening to.</p>
        <p>His work has been shown in group and solo exhibitions. Commissions are available on a limited seasonal basis.</p>
      </div>
    </div>
  </section>
  <section class="practice">
    <div class="practice-inner">
      <h2 class="reveal">The Practice</h2>
      <div class="practice-grid">
        {[
          { label:'Mediums', value:'Oil, watercolor, charcoal, acrylic, mixed media, collage, ink' },
          { label:'Subjects', value:'Landscape, abstraction, figure, still life — often in dialogue with each other' },
          { label:'Studio', value:'United States' },
          { label:'Commissions', value:'Seasonal availability — inquire through the commissions page' },
          { label:'Prints', value:'Limited-edition giclee prints of selected works' },
          { label:'Faith', value:'Informed by a contemplative, Christ-centered view of beauty and creation' },
        ].map(item => (
          <div class="practice-item reveal"><dt>{item.label}</dt><dd>{item.value}</dd></div>
        ))}
      </div>
    </div>
  </section>
  <section class="statement reveal">
    <div class="statement-inner">
      <p class="eyebrow">Artist Statement</p>
      <blockquote>"I make work because there are things I can't say any other way. The materials have their own intelligence — the way watercolor blooms, the way charcoal smears, the way paint dries differently depending on how much it wanted to be there. I follow that. The piece tells me when it's done."</blockquote>
      <cite>— Justin</cite>
    </div>
  </section>
  <section class="press reveal">
    <div class="press-inner">
      <h2>Press & Media</h2>
      <p>For interviews, editorial inquiries, or exhibition proposals, please use the contact form.</p>
      <a href="/contact" class="btn-outline">Get in Touch</a>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
<style>
  .about-hero { padding:7rem 2.5rem 5rem; max-width:1280px; margin:0 auto; }
  .about-hero-inner { display:grid; grid-template-columns:420px 1fr; gap:6rem; align-items:center; }
  .about-hero-img { position:relative; }
  .img-placeholder.portrait { height:560px; background:#EDE8DF; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; border:1px dashed #8B7355; color:#8B7355; font-size:0.8rem; text-align:center; padding:1.5rem; }
  .img-placeholder.portrait span { font-family:'Playfair Display',serif; font-size:1rem; color:#3D3D3A; font-weight:600; }
  .accent-mark { position:absolute; top:-1.5rem; right:-1.5rem; width:120px; height:120px; border:2px solid #C4622D; z-index:-1; }
  .eyebrow { font-size:0.75rem; letter-spacing:0.16em; text-transform:uppercase; color:#C4622D; margin-bottom:1rem; }
  .about-hero-text h1 { font-family:'Playfair Display',serif; font-size:clamp(3rem,5vw,4.5rem); font-weight:700; letter-spacing:-0.02em; margin-bottom:1.5rem; }
  .lead { font-size:1.125rem; line-height:1.75; color:#1A1A18; margin-bottom:1.25rem; }
  .about-hero-text p { color:#3D3D3A; line-height:1.75; margin-bottom:1rem; }
  .practice { background:#1A1A18; color:#EDE8DF; padding:5rem 2.5rem; }
  .practice-inner { max-width:1280px; margin:0 auto; }
  .practice h2 { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3rem); font-weight:600; letter-spacing:-0.02em; margin-bottom:3rem; padding-bottom:1.5rem; border-bottom:1px solid rgba(237,232,223,0.1); }
  .practice-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2rem 3rem; }
  .practice-item dt { font-size:0.75rem; letter-spacing:0.12em; text-transform:uppercase; color:#C4622D; margin-bottom:0.5rem; }
  .practice-item dd { font-size:0.9375rem; color:#8B7355; line-height:1.6; }
  .statement { max-width:960px; margin:6rem auto; padding:0 2.5rem; text-align:center; }
  .statement blockquote { font-family:'Playfair Display',serif; font-size:clamp(1.25rem,2.5vw,1.875rem); font-style:italic; line-height:1.55; color:#1A1A18; margin:1.5rem 0 1rem; }
  .statement cite { font-size:0.875rem; letter-spacing:0.06em; color:#8B7355; }
  .press { background:#EDE8DF; padding:4rem 2.5rem; text-align:center; }
  .press-inner { max-width:640px; margin:0 auto; }
  .press h2 { font-family:'Playfair Display',serif; font-size:2rem; font-weight:600; margin-bottom:1rem; letter-spacing:-0.02em; }
  .press p { color:#3D3D3A; margin-bottom:2rem; line-height:1.7; }
  .btn-outline { display:inline-block; border:1px solid #C4622D; color:#C4622D; padding:0.75rem 1.75rem; font-size:0.875rem; letter-spacing:0.06em; text-transform:uppercase; font-family:'DM Sans',sans-serif; transition:background 0.25s,color 0.25s; }
  .btn-outline:hover { background:#C4622D; color:#F7F4EE; }
  @media (max-width:1024px) { .about-hero-inner { grid-template-columns:1fr; gap:3rem; } .practice-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px) { .about-hero,.statement { padding-inline:1.5rem; } .practice-grid { grid-template-columns:1fr; } }
</style>
